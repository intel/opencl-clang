
#ifndef GFKERNELSUPPORT_KERNELCORE_H
#define GFKERNELSUPPORT_KERNELCORE_H

#define GF_DEVICE_TARGET_CUDA 0

#define GF_DEVICE_TARGET_OPENCL 1

#define GF_DEVICE_TARGET_HOST 0

#define GF_KERNEL __kernel void

#define GF_DEVICE_FUNCTION

#define GF_HOST_FUNCTION

#define GF_CONSTANT(T) __constant T

#define GF_CONSTANT_PTR(T) GF_PTR(T)

#define GF_CUDA_CONSTANT(T, N)

#define GF_OPENCL_CONSTANT(T, N) GF_PTR(T) N

#define GF_GET_CONSTANT(P) P

#define GF_STATIC_CONSTANT_PTR(T) GF_CONSTANT(T*)

#define GF_SHARED(T) __local T

#define GF_SHARED_PTR(T) __local T*

#define GF_CUDA_SHARED_DYNAMIC(T, N)

#define GF_OPENCL_SHARED_DYNAMIC(T, N) GF_SHARED_PTR(T) N

#define GF_PTR(T) __global T*

#define GF_ALIGN(N) __attribute__ ((aligned (N)))

#define GF_FASTMULTIPLY(X, Y) mul24(X, Y)

#define GF_READ2D(I, R, X, Y) (I)[GF_FASTMULTIPLY(Y, R) + (X)]

#define GF_WRITE2D(P, I, R, X, Y) (I)[GF_FASTMULTIPLY(Y, R) + (X)] = (P)

#define GF_TEXTURE(T, N, S) constant sampler_t kSampler_##N = S;
#define GF_NORMALIZED_TEXTURE(T, N, S) constant sampler_t kSampler_##N = S;
#define GF_OPENCL_TEXTURE(N) __read_only image2d_t N

#define GF_GET_TEXTURE(T) T

#define GF_READTEXTURE(I, X, Y) read_imagef(I, kSampler_##I, (float2)(X, Y))

#ifndef make_int2
#define make_int2(X, Y) (int2)(X, Y)
#endif

#ifndef make_float4
#define make_float4(X, Y, Z, W) (float4)(X, Y, Z, W)
#endif

#ifndef make_float3
#define make_float3(X, Y, Z) (float3)(X, Y, Z)
#endif

#ifndef make_float2
#define make_float2(X, Y) (float2)(X, Y)
#endif

#ifndef make_uchar4
#define make_uchar4(X, Y, Z, W) (uchar4)(X, Y, Z, W)
#endif

#ifndef make_ushort4
#define make_ushort4(X, Y, Z, W) (ushort4)(X, Y, Z, W)
#endif

#ifndef make_uint4
#define make_uint4(X, Y, Z, W) (uint4)(X, Y, Z, W)
#endif
GF_DEVICE_FUNCTION int KernelX() { return get_global_id(0); } GF_DEVICE_FUNCTION int KernelY() { return get_global_id(1); } GF_DEVICE_FUNCTION int2 ThreadID() { return make_int2(get_local_id(0), get_local_id(1)); } GF_DEVICE_FUNCTION int2 BlockID() { return make_int2(get_group_id(0), get_group_id(1)); } GF_DEVICE_FUNCTION int2 BlockSize() { return make_int2(get_local_size(0), get_local_size(1)); } GF_DEVICE_FUNCTION float saturate(float inX) { return clamp(inX, 0.0f, 1.0f); } GF_DEVICE_FUNCTION void SyncThreads() { barrier(CLK_LOCAL_MEM_FENCE); }
#endif
GF_DEVICE_FUNCTION float2 AddFloat2s( float2 inValue0, float2 inValue1) { float2 result = { inValue0.x + inValue1.x, inValue0.y + inValue1.y }; return result; } GF_DEVICE_FUNCTION float2 SubtractFloat2s( float2 inValue0, float2 inValue1) { float2 result = { inValue0.x - inValue1.x, inValue0.y - inValue1.y, }; return result; } GF_DEVICE_FUNCTION float2 MultiplyFloat2( float2 inValue, float inScalar) { float2 result = { inValue.x * inScalar, inValue.y * inScalar, }; return result; }GF_DEVICE_FUNCTION float2 DivideFloat2( float2 inValue, float inScalar) { float2 result = { inValue.x / inScalar, inValue.y / inScalar }; return result; }GF_DEVICE_FUNCTION float4 AddFloat4s( float4 inValue0, float4 inValue1) { float4 result = { inValue0.x + inValue1.x, inValue0.y + inValue1.y, inValue0.z + inValue1.z, inValue0.w + inValue1.w }; return result; } GF_DEVICE_FUNCTION float4 SubtractFloat4s( float4 inValue0, float4 inValue1) { float4 result = { inValue0.x - inValue1.x, inValue0.y - inValue1.y, inValue0.z - inValue1.z, inValue0.w - inValue1.w }; return result; } GF_DEVICE_FUNCTION float4 MultiplyFloat4( float4 inValue, float inScalar) { float4 result = { inValue.x * inScalar, inValue.y * inScalar, inValue.z * inScalar, inValue.w * inScalar }; return result; }GF_DEVICE_FUNCTION float4 DivideFloat4( float4 inValue, float inScalar) { float4 result = { inValue.x / inScalar, inValue.y / inScalar, inValue.z / inScalar, inValue.w / inScalar }; return result; }GF_DEVICE_FUNCTION int __max_i( int a, int b) { return (a > b) ? a : b; } GF_DEVICE_FUNCTION int __min_i( int a, int b) { return (a < b) ? a : b; } GF_DEVICE_FUNCTION float __max_f( float a, float b) { return (a > b) ? a : b; } GF_DEVICE_FUNCTION float __min_f( float a, float b) { return (a < b) ? a : b; }
#define BLK_MATCH_COST_TRUNC_THRESH 0.3f

#define INVALID_FLOW_VAL 1e12f

#define UNKNOWN_FLOW_THRESH 1e8f
GF_TEXTURE(float4, im1Tex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_LINEAR); GF_TEXTURE(float4, im2Tex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_LINEAR); GF_TEXTURE(float2, uvTex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_NEAREST); GF_TEXTURE(float4, lum1Tex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_LINEAR); GF_TEXTURE(float4, lum2Tex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_LINEAR); GF_TEXTURE(float2, fwdUVTex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_NEAREST); GF_TEXTURE(float2, bwdUVTex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_NEAREST); GF_TEXTURE(float4, im1RGBTex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_LINEAR); GF_TEXTURE(float4, im2RGBTex, CLK_NORMALIZED_COORDS_FALSE | CLK_ADDRESS_CLAMP_TO_EDGE | CLK_FILTER_LINEAR);GF_DEVICE_FUNCTION float __d_square_root( float val) { return sqrt(val); } GF_DEVICE_FUNCTION int __d_atomic_exchange( GF_PTR(int) address, int val) { return atomic_xchg(address, val); } GF_DEVICE_FUNCTION int __d_atomic_add( GF_PTR(int) address, int val) { return atomic_add(address, val); } GF_DEVICE_FUNCTION int __d_atomic_cas( GF_PTR(int) address, int compare, int val) { return atomic_cmpxchg(address, compare, val); } GF_DEVICE_FUNCTION float2 __d_read_uv_texture( int x, int y, GF_OPENCL_TEXTURE(uvTex)) { float4 uv = GF_READTEXTURE(uvTex, x, y); return make_float2(uv.x, uv.y); } GF_DEVICE_FUNCTION float2 __d_read_fwduv_texture( int x, int y, GF_OPENCL_TEXTURE(fwdUVTex)) { float4 uv = GF_READTEXTURE(fwdUVTex, x, y); return make_float2(uv.x, uv.y); } GF_DEVICE_FUNCTION float2 __d_read_bwduv_texture( int x, int y, GF_OPENCL_TEXTURE(bwdUVTex)) { float4 uv = GF_READTEXTURE(bwdUVTex, x, y); return make_float2(uv.x, uv.y); }typedef union { int as_int; float as_float; } float_int_union; GF_DEVICE_FUNCTION float __d_atomic_min( GF_PTR(float) address_io, float val_in) { float_int_union mine; float_int_union theirs; mine.as_float = val_in; theirs.as_int = *(GF_PTR(int))(address_io); for (int old_as_int = mine.as_int; mine.as_float < theirs.as_float && theirs.as_int != old_as_int;) { old_as_int = theirs.as_int; theirs.as_int = __d_atomic_cas((GF_PTR(int))(address_io), old_as_int, mine.as_int); } return theirs.as_float; } GF_DEVICE_FUNCTION float __d_atomic_cas_float( GF_PTR(float) address_in, float compare_in, float val_in) { float_int_union compare; float_int_union val; compare.as_float = compare_in; val.as_float = val_in; compare.as_int = __d_atomic_cas((GF_PTR(int))(address_in), compare.as_int, val.as_int); return compare.as_float; }GF_KERNEL _d_compose_multichannel_data_kernel( GF_PTR(float4) data, GF_PTR(float4) im_rgb, int mem_w, int width, int height) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { int id = id_y*mem_w + id_x; float4 pix_rgb = im_rgb[id]; float4 pix; pix.x = pix_rgb.x / 255.f; pix.y = pix_rgb.y / 255.f; pix.z = pix_rgb.z / 255.f; pix.w = 0; data[id] = pix; } }GF_DEVICE_FUNCTION float __d_squared_sum_dist( float4 pix) { return (pix.x*pix.x + pix.y*pix.y + pix.z*pix.z); } GF_DEVICE_FUNCTION float __d_lk_update_motion_vector( float2* vec, int blk_x, int blk_y, int width, int height, int blk_sz, int blk_overlap, float err_thresh, GF_OPENCL_TEXTURE(lum1Tex), GF_OPENCL_TEXTURE(lum2Tex)) { int blk_margin = blk_sz - blk_overlap; float2 c1 = make_float2(blk_x*blk_margin, blk_y*blk_margin); float2 c2 = AddFloat2s(c1, *vec); float4 gtg = make_float4(0,0,0,0); float2 gtz = make_float2(0,0); float sumSquareZ = 0; float sumabsz = 0; int dy_st = 0; int dy_ed = blk_sz; int dx_st = 0; int dx_ed = blk_sz; if (c2.x+blk_sz <= 0 || c2.x >= width-1 || c2.y+blk_sz<=0 || c2.y>=height-1) { return FLT_MAX; } if (c2.y < 0) { dy_st = 0 - (int)c2.y; } if (__max_f(c1.y,c2.y)+blk_sz >= height) { dy_ed = blk_sz - (__max_f(c1.y,c2.y)+blk_sz-height); } if (c2.x < 0) { dx_st = 0 - (int)c2.x; } if (__max_f(c1.x,c2.x)+blk_sz >= width) { dx_ed = blk_sz - (__max_f(c1.x,c2.x)+blk_sz-width); } int sumPixelsVisited = 0; for (int dy=dy_st; dy<dy_ed; dy++) { for (int dx=dx_st; dx<dx_ed; dx++) { float4 zzz = SubtractFloat4s(GF_READTEXTURE(lum1Tex,c1.x+(float)(dx)+0.5f,c1.y+(float)(dy)+0.5f), GF_READTEXTURE(lum2Tex,c2.x+(float)(dx)+0.5f,c2.y+(float)(dy)+0.5f)); sumabsz += ((fabs(zzz.x)+fabs(zzz.y)+fabs(zzz.z))/3.f); sumSquareZ += __d_squared_sum_dist(zzz); sumPixelsVisited ++; float4 grad_x = DivideFloat4(SubtractFloat4s(GF_READTEXTURE(lum2Tex,c2.x+(float)(dx+1)+0.5f,c2.y+(float)(dy )+0.5f), GF_READTEXTURE(lum2Tex,c2.x+(float)(dx-1)+0.5f,c2.y+(float)(dy )+0.5f)), 2.f); float4 grad_y = DivideFloat4(SubtractFloat4s(GF_READTEXTURE(lum2Tex,c2.x+(float)(dx )+0.5f,c2.y+(float)(dy+1)+0.5f), GF_READTEXTURE(lum2Tex,c2.x+(float)(dx )+0.5f,c2.y+(float)(dy-1)+0.5f)), 2.f); gtg.x += grad_x.x * grad_x.x; gtg.x += grad_x.y * grad_x.y; gtg.x += grad_x.z * grad_x.z; gtg.y += grad_x.x * grad_y.x; gtg.y += grad_x.y * grad_y.y; gtg.y += grad_x.z * grad_y.z; gtg.z += grad_y.x * grad_y.x; gtg.z += grad_y.y * grad_y.y; gtg.z += grad_y.z * grad_y.z; gtz.x += grad_x.x * zzz.x; gtz.x += grad_x.y * zzz.y; gtz.x += grad_x.z * zzz.z; gtz.y += grad_y.x * zzz.x; gtz.y += grad_y.y * zzz.y; gtz.y += grad_y.z * zzz.z; } } if (sumPixelsVisited<=blk_sz) { return FLT_MAX; } gtg = DivideFloat4(gtg, (float)sumPixelsVisited); gtz = DivideFloat2(gtz, (float)sumPixelsVisited); sumSquareZ /= (float)sumPixelsVisited; float meanZ = sumabsz / (float)sumPixelsVisited; if (meanZ<err_thresh) { return 0.0f; } float a = gtg.x; float c = gtg.y; float b = gtg.z; float squareRoot = __d_square_root( (a+b)*(a+b) - 4 * (a * b - c*c)); float lambda1 = ( (a+b) + squareRoot ) / 2.0f; float lambda2 = ( (a+b) - squareRoot ) / 2.0f; float lambdaMax = __max_f(fabs(lambda1),fabs(lambda2)); float lambdaMin = __min_f(fabs(lambda1),fabs(lambda2)); float R = lambdaMin==0.0f?FLT_MAX:(lambdaMax / lambdaMin); float2 u = make_float2(0,0); if (R>10) { float2 E; if (c==0) { E = make_float2(0, 1); } else { E = make_float2(1, (lambdaMax-a)/c); E = DivideFloat2(E, __d_square_root(E.x*E.x+E.y*E.y)); } float alpha = (E.x*gtz.x + E.y*gtz.y)/(lambdaMax+1e-6f); u = MultiplyFloat2(E, alpha); } else { float mu = 0.1f * R * (sumSquareZ); float4 C = AddFloat4s(gtg, make_float4(mu,0,mu,0)); float tdiv = 1.f/(C.x*C.z - C.y*C.y); float4 TC; TC.x = C.z; TC.y = -C.y; TC.z = C.x; TC = MultiplyFloat4(TC, tdiv); u.x = TC.x*gtz.x + TC.y*gtz.y; u.y = TC.y*gtz.x + TC.z*gtz.y; } *vec = AddFloat2s(*vec, u); return meanZ; } GF_DEVICE_FUNCTION float __d_quantize( float x, float base) { return (float)round(x*base) / base; } GF_KERNEL _d_lucas_kanade_kernel( GF_PTR(float2) blk_uv, int uv_mem_w, int num_blk_x, int num_blk_y, int width, int height, int blk_sz, int blk_overlap, int num_iteration, float err_thresh, GF_OPENCL_TEXTURE(lum1Tex), GF_OPENCL_TEXTURE(lum2Tex)) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < num_blk_x && id_y < num_blk_y) { float curDfd = FLT_MAX; float2 bestVector = blk_uv[id_y*uv_mem_w + id_x]; float bestDfd = curDfd; int count = 0; float2 curVector = bestVector; while (curDfd>0.0f && count<num_iteration) { curDfd = __d_lk_update_motion_vector(&curVector, id_x, id_y, width, height, blk_sz, blk_overlap, err_thresh, GF_GET_TEXTURE(lum1Tex), GF_GET_TEXTURE(lum2Tex)); if (curDfd<bestDfd) { bestDfd = curDfd; bestVector = curVector; } count++; } blk_uv[id_y*uv_mem_w + id_x] = bestVector; } }GF_DEVICE_FUNCTION bool __d_has_exist( float2* vec_candidates, int num_candidates) { bool has_exist = false; for (int i=0; i < num_candidates; i++) { if (vec_candidates[num_candidates].x == vec_candidates[i].x && vec_candidates[num_candidates].y == vec_candidates[i].y) { has_exist=true; } } return has_exist; } GF_DEVICE_FUNCTION float __d_euc_dist( float4 pix) { return __min_f(1.f, (fabs(pix.x) + fabs(pix.y) + fabs(pix.z))/3.f); } GF_DEVICE_FUNCTION float __d_blk_match_cost_texmem( int cx1, int cy1, int cx2, int cy2, int blk_sz, float cost_cutoff, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex)) { float cost = 0.f; for (int dy=0; dy<blk_sz; dy++) { for (int dx=0; dx<blk_sz; dx++) { float4 pix_diff_f4 = SubtractFloat4s( GF_READTEXTURE(im1Tex, cx1+dx, cy1+dy), GF_READTEXTURE(im2Tex, cx2+dx, cy2+dy)); float diff = __d_euc_dist(pix_diff_f4); cost += __min_f(fabs(diff), BLK_MATCH_COST_TRUNC_THRESH); if (cost > cost_cutoff) { return cost; } } } return cost; } GF_DEVICE_FUNCTION float __d_blk_match_cost_texmem_lerp( float2 c1, float2 c2, int blk_sz, float cost_cutoff, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex)) { float cost = 0.f; for (int dy=0; dy<blk_sz; dy++) { for (int dx=0; dx<blk_sz; dx++) { float4 pix_diff_f4 = SubtractFloat4s( GF_READTEXTURE(im1Tex, c1.x+(float)dx+0.5f, c1.y+(float)dy+0.5f), GF_READTEXTURE(im2Tex, c2.x+(float)dx+0.5f, c2.y+(float)dy+0.5f)); float diff = __d_euc_dist(pix_diff_f4); cost += __min_f(fabs(diff), BLK_MATCH_COST_TRUNC_THRESH); if (cost > cost_cutoff) { return cost; } } } return cost; } GF_DEVICE_FUNCTION float __d_blkmv_smooth_cost( float2 cur_vec, float2 mean_vec, float global_smoothness) { float2 diff = SubtractFloat2s(cur_vec, mean_vec); return ((fabs(diff.x)+fabs(diff.y)) / 400.f) * (global_smoothness+1) / 255.f; } GF_DEVICE_FUNCTION int _ADD_TO_MV_ARRAY( int xx, int yy, float2* vec_array, int cur_pos, float2* vec_sum, GF_OPENCL_TEXTURE(uvTex)) { vec_array[cur_pos] = __d_read_uv_texture(xx, yy, GF_GET_TEXTURE(uvTex)); *vec_sum = AddFloat2s(*vec_sum, vec_array[cur_pos]); if (!__d_has_exist(vec_array,cur_pos)) { cur_pos++; } return cur_pos; } GF_DEVICE_FUNCTION int COLLECT_MV_CANDID_NEARBY( int xx, int yy, float2* vec_array, float2* vec_sum, GF_OPENCL_TEXTURE(uvTex)) { int num_candidates = 0; num_candidates = _ADD_TO_MV_ARRAY(xx, yy, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx-1, yy, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx+1, yy, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx, yy-1, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx-1, yy-1, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx+1, yy-1, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx, yy+1, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx-1, yy+1, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); num_candidates = _ADD_TO_MV_ARRAY(xx+1, yy+1, vec_array, num_candidates, vec_sum, GF_GET_TEXTURE(uvTex)); return num_candidates; } GF_KERNEL _d_block_vec_smoothing_kernel_texmem_time( GF_PTR(float2) uv_out, int uv_mem_w, int num_blk_x, int num_blk_y, int blk_sz, int blk_overlap, float global_smoothness, float time_delta, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex), GF_OPENCL_TEXTURE(uvTex)) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < num_blk_x && id_y < num_blk_y) { float2 mean_vec = make_float2(0,0); float2 vec_candidates[9] = {0}; int num_candidates = COLLECT_MV_CANDID_NEARBY(id_x, id_y, vec_candidates, &mean_vec, GF_GET_TEXTURE(uvTex)); mean_vec = DivideFloat2(mean_vec, 9.f); float2 best_vec = vec_candidates[0]; float best_total_cost = 1e8f; if (num_candidates>1) { int margin = blk_sz - blk_overlap; int cur_x = id_x*margin; int cur_y = id_y*margin; for (int i=0; i<num_candidates; i++) { float2 cur_vec = vec_candidates[i]; float2 pos1 = make_float2(cur_x-cur_vec.x*time_delta, cur_y-cur_vec.y*time_delta); float2 pos2 = make_float2(cur_x+cur_vec.x*(1.f-time_delta), cur_y+cur_vec.y*(1.f-time_delta)); float data_cost = __d_blk_match_cost_texmem_lerp(pos1,pos2,blk_sz,best_total_cost, GF_GET_TEXTURE(im1Tex), GF_GET_TEXTURE(im2Tex)); float smooth_cost = __d_blkmv_smooth_cost(cur_vec, mean_vec, global_smoothness) * (blk_sz*blk_sz); if (data_cost + smooth_cost < best_total_cost) { best_total_cost = data_cost + smooth_cost; best_vec = vec_candidates[i]; } } } uv_out[id_y*uv_mem_w + id_x] = best_vec; } } GF_KERNEL _d_refine_mv_blk_to_pix_kernel_texmem_time( GF_PTR(float2) uv_out, int uv_mem_w, int width, int height, int blk_sz, int blk_overlap, float time_delta, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex), GF_OPENCL_TEXTURE(uvTex)) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { int margin = blk_sz - blk_overlap; int blk_idx_x = id_x / margin; int blk_idx_y = id_y / margin; float2 mean_vec = make_float2(0,0); float2 vec_candidates[9] = {0}; int num_candidates = COLLECT_MV_CANDID_NEARBY(blk_idx_x, blk_idx_y, vec_candidates, &mean_vec, GF_GET_TEXTURE(uvTex)); float min_diff = 1e8f; float2 best_vec = vec_candidates[0]; for (int i=0; i<num_candidates; i++) { float2 cur_vec = vec_candidates[i]; float4 pix_diff_f4 = SubtractFloat4s( GF_READTEXTURE(im1Tex, id_x-cur_vec.x*( time_delta)+0.5f, id_y-cur_vec.y*( time_delta) +0.5f), GF_READTEXTURE(im2Tex, id_x+cur_vec.x*(1.f-time_delta)+0.5f, id_y+cur_vec.y*(1.f-time_delta)+0.5f)); float pix_diff = __d_euc_dist(pix_diff_f4); if (pix_diff < min_diff) { min_diff = pix_diff; best_vec = cur_vec; } } uv_out[id_y*uv_mem_w + id_x] = best_vec; } }GF_DEVICE_FUNCTION float __d_pixmv_smooth_cost( float2 cur_vec, float2 mean_vec, float local_smoothness) { float2 diff = SubtractFloat2s(cur_vec, mean_vec); return ((fabs(diff.x)+fabs(diff.y)) * 8) * (local_smoothness+1); } GF_KERNEL _d_pixel_vec_smoothing_kernel_texmem_time( GF_PTR(float2) uv_out, int uv_mem_w, int width, int height, float local_smoothness, float time_delta, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex), GF_OPENCL_TEXTURE(uvTex)) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { float2 mean_vec = make_float2(0,0); float2 vec_candidates[9] = {0}; int num_candidates = COLLECT_MV_CANDID_NEARBY(id_x, id_y, vec_candidates, &mean_vec, GF_GET_TEXTURE(uvTex)); mean_vec = DivideFloat2(mean_vec, 9.f); float best_total_cost = 1e8f; float2 best_vec = vec_candidates[0]; if (num_candidates>1) { for (int i=0; i<num_candidates; i++) { float2 cur_vec = vec_candidates[i]; float4 pix_diff_f4 = SubtractFloat4s( GF_READTEXTURE(im1Tex, id_x-cur_vec.x*( time_delta)+0.5f, id_y-cur_vec.y*( time_delta)+0.5f), GF_READTEXTURE(im2Tex, id_x+cur_vec.x*(1.f-time_delta)+0.5f, id_y+cur_vec.y*(1.f-time_delta)+0.5f)); float data_cost = __d_euc_dist(pix_diff_f4); float smooth_cost = __d_pixmv_smooth_cost(cur_vec, mean_vec, local_smoothness); if (data_cost + smooth_cost < best_total_cost) { best_total_cost = data_cost + smooth_cost; best_vec = vec_candidates[i]; } } } uv_out[id_y*uv_mem_w + id_x] = best_vec; } }GF_DEVICE_FUNCTION bool __d_is_invalid_flow( float2 uv_val) { if (fabs(uv_val.x) >= (UNKNOWN_FLOW_THRESH) || fabs(uv_val.y) >= (UNKNOWN_FLOW_THRESH)) { return true; } else { return false; } } GF_DEVICE_FUNCTION int __d_accumulate_valid_uv( float2* uv_sum, int valid_count, int xx, int yy, int dx, int dy, GF_OPENCL_TEXTURE(uvTex)) { float2 tmp = __d_read_uv_texture(xx+dx, yy+dy, GF_GET_TEXTURE(uvTex)); for (int cnt=1; __d_is_invalid_flow(tmp) && cnt<10; cnt++) { tmp = __d_read_uv_texture(xx+dx*cnt, yy+dy*cnt, GF_GET_TEXTURE(uvTex)); } if (!__d_is_invalid_flow(tmp)) { *uv_sum = AddFloat2s(*uv_sum, tmp); valid_count++; } return valid_count; } GF_DEVICE_FUNCTION int ACCUMULATE_VALID_MV_CANDID_NONLOCAL( int xx, int yy, float2* vec_sum, GF_OPENCL_TEXTURE(uvTex)) { int valid_mv_count = 0; valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy,-1, 0, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy, 1, 0, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy, 0,-1, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy,-1,-1, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy, 1,-1, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy, 0, 1, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy,-1, 1, GF_GET_TEXTURE(uvTex)); valid_mv_count = __d_accumulate_valid_uv(vec_sum,valid_mv_count,xx,yy, 1, 1, GF_GET_TEXTURE(uvTex)); return valid_mv_count; } GF_DEVICE_FUNCTION int __d_fetch_valid_fwduv( float2* vec_array, int cur_pos, int* num_neigh, float2* uv_sum, int xx, int yy, int dx, int dy, GF_OPENCL_TEXTURE(fwdUVTex)) { vec_array[cur_pos] = __d_read_fwduv_texture(xx+dx, yy+dy, GF_GET_TEXTURE(fwdUVTex)); for (int cnt=1; __d_is_invalid_flow(vec_array[cur_pos]) && cnt<5; cnt++) { vec_array[cur_pos] = __d_read_fwduv_texture(xx+dx*cnt, yy+dy*cnt, GF_GET_TEXTURE(fwdUVTex)); } if (!__d_is_invalid_flow(vec_array[cur_pos])) { *uv_sum = AddFloat2s(*uv_sum, vec_array[cur_pos]); (*num_neigh)++; if (!__d_has_exist(vec_array,cur_pos)) { cur_pos++; } } return cur_pos; } GF_DEVICE_FUNCTION int _ADD_TO_MV_ARRAY_NONLOCAL_FWD( int xx, int yy, int dx, int dy, float2* vec_array, int cur_pos, int* num_neigh, float2* vec_sum, GF_OPENCL_TEXTURE(fwdUVTex)) { return __d_fetch_valid_fwduv(vec_array,cur_pos,num_neigh,vec_sum,xx,yy,dx,dy, GF_GET_TEXTURE(fwdUVTex)); } GF_DEVICE_FUNCTION int COLLECT_MV_CANDID_NONLOCAL_FWD( int xx, int yy, float2* vec_array, float2* vec_sum, int* num_neigh, GF_OPENCL_TEXTURE(fwdUVTex)) { int num_cand = 0; *num_neigh=0; num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy,-1, 0,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy, 1, 0,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy, 0,-1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy,-1,-1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy, 1,-1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy, 0, 1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy,-1, 1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_FWD(xx,yy, 1, 1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(fwdUVTex)); return num_cand; } GF_DEVICE_FUNCTION int __d_fetch_valid_bwduv( float2* vec_array, int cur_pos, int* num_neigh, float2* uv_sum, int xx, int yy, int dx, int dy, GF_OPENCL_TEXTURE(bwdUVTex)) { vec_array[cur_pos] = __d_read_bwduv_texture(xx+dx, yy+dy, GF_GET_TEXTURE(bwdUVTex)); for (int cnt=1; __d_is_invalid_flow(vec_array[cur_pos]) && cnt<5; cnt++) { vec_array[cur_pos] = __d_read_bwduv_texture(xx+dx*cnt, yy+dy*cnt, GF_GET_TEXTURE(bwdUVTex)); } if (!__d_is_invalid_flow(vec_array[cur_pos])) { *uv_sum = AddFloat2s(*uv_sum, vec_array[cur_pos]); (*num_neigh)++; if (!__d_has_exist(vec_array,cur_pos)) { cur_pos++; } } return cur_pos; } GF_DEVICE_FUNCTION int _ADD_TO_MV_ARRAY_NONLOCAL_BWD( int xx, int yy, int dx, int dy, float2* vec_array, int cur_pos, int* num_neigh, float2* vec_sum, GF_OPENCL_TEXTURE(bwdUVTex)) { return __d_fetch_valid_bwduv(vec_array,cur_pos,num_neigh,vec_sum,xx,yy,dx,dy, GF_GET_TEXTURE(bwdUVTex)); } GF_DEVICE_FUNCTION int COLLECT_MV_CANDID_NONLOCAL_BWD( int xx, int yy, float2* vec_array, float2* vec_sum, int* num_neigh, GF_OPENCL_TEXTURE(bwdUVTex)) { int num_cand = 0; *num_neigh=0; num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy,-1, 0,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy, 1, 0,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy, 0,-1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy,-1,-1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy, 1,-1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy, 0, 1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy,-1, 1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); num_cand = _ADD_TO_MV_ARRAY_NONLOCAL_BWD(xx,yy, 1, 1,vec_array,num_cand,num_neigh,vec_sum, GF_GET_TEXTURE(bwdUVTex)); return num_cand; } GF_KERNEL _d_warp_flow_without_matching_cost_kernel_firstpass( GF_PTR(float2) uv_out, GF_PTR(float2) uv_in, int uv_mem_w, GF_PTR(int) count_map, int bufi_mem_w, int width, int height, float time_delta, float local_smoothness) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { float2 cur_pos = make_float2(id_x, id_y); float2 cur_vec = uv_in[id_y*uv_mem_w + id_x]; if (__d_is_invalid_flow(cur_vec)) { return; } float2 tgt_pos = AddFloat2s(cur_pos, MultiplyFloat2(cur_vec, time_delta)); int tgt_pos_x = round(tgt_pos.x); int tgt_pos_y = round(tgt_pos.y); if (tgt_pos_x < 0 || tgt_pos_x >= width || tgt_pos_y <0 || tgt_pos_y >= height) { return; } if (__d_atomic_add(&count_map[tgt_pos_y*bufi_mem_w + tgt_pos_x], 1) == 0) { uv_out[tgt_pos_y*uv_mem_w + tgt_pos_x] = cur_vec; } } } GF_KERNEL _d_warp_flow_without_matching_cost_kernel_firstpass_deduplicate( GF_PTR(float2) uv_out, int uv_mem_w, GF_PTR(int) count_map, int bufi_mem_w, int width, int height) { if (KernelX() < width && KernelY() < height && count_map[KernelY() * bufi_mem_w + KernelX()] > 1) { uv_out[KernelY() * uv_mem_w + KernelX()] = make_float2(INVALID_FLOW_VAL,INVALID_FLOW_VAL); } }GF_DEVICE_FUNCTION float4 __d_read_texture4_offset( int2 base, float2 offset, float delta, GF_OPENCL_TEXTURE(im1Tex)) { float4 result = GF_READTEXTURE(im1Tex, (float)base.x + offset.x * delta + 0.5f, (float)base.y + offset.y * delta + 0.5f); return result; } GF_DEVICE_FUNCTION int Index( int2 pos, int pitch) { return pos.x + pos.y * pitch; } GF_KERNEL _d_warp_flow_kernel_make_splats( GF_PTR(float) d_cost_map, int cost_mem_w, GF_PTR(float2) splat_upper, GF_PTR(float2) splat_lower, int splat_mem_w, GF_PTR(float2) uv_in, int uv_mem_w, int width, int height, float time_delta, float local_smoothness, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex), GF_OPENCL_TEXTURE(uvTex)) { int2 id = make_int2(KernelX(), KernelY()); if (id.x < width && id.y < height) { float local_costs[4]; float2 cur_vec = uv_in[Index(id, uv_mem_w)]; for (int nearby = 0; nearby < 4; nearby++) { local_costs[nearby] = INVALID_FLOW_VAL; if (!__d_is_invalid_flow(cur_vec)) { float2 tgt_pos = AddFloat2s(make_float2(id.x, id.y), MultiplyFloat2(cur_vec, time_delta)); int2 splat_pos = make_int2( (int)(nearby & 1 ? ceil(tgt_pos.x) : floor(tgt_pos.x)), (int)(nearby & 2 ? ceil(tgt_pos.y) : floor(tgt_pos.y))); if (splat_pos.x >= 0 && splat_pos.x < width && splat_pos.y >= 0 && splat_pos.y < height) { float4 pix_diff_f4 = SubtractFloat4s( __d_read_texture4_offset(splat_pos, cur_vec, -time_delta, GF_GET_TEXTURE(im1Tex)), __d_read_texture4_offset(splat_pos, cur_vec, -time_delta + 1.f, GF_GET_TEXTURE(im2Tex))); float pix_diff = __d_euc_dist(pix_diff_f4); float2 mean_vec = make_float2(0, 0); int valid_mv_count = ACCUMULATE_VALID_MV_CANDID_NONLOCAL(splat_pos.x, splat_pos.y, &mean_vec, GF_GET_TEXTURE(uvTex)); if (valid_mv_count) { mean_vec = DivideFloat2(mean_vec, (float)valid_mv_count); float smoothness = __d_pixmv_smooth_cost(cur_vec, mean_vec, local_smoothness); float match_cost = pix_diff + smoothness; GF_PTR(float) address = &d_cost_map[Index(splat_pos, cost_mem_w)]; if (match_cost < __d_atomic_min(address, match_cost)) { local_costs[nearby] = match_cost; } } } } } splat_upper[Index(id, splat_mem_w)] = make_float2(local_costs[0], local_costs[1]); splat_lower[Index(id, splat_mem_w)] = make_float2(local_costs[2], local_costs[3]); } } GF_KERNEL _d_warp_flow_kernel_splatter( GF_PTR(float) d_cost_map, int cost_mem_w, GF_PTR(float2) d_splat_upper, GF_PTR(float2) d_splat_lower, int splat_mem_w, GF_PTR(float2) uv_out, GF_PTR(float2) uv_in, int uv_mem_w, int width, int height, float time_delta) { int2 id = make_int2(KernelX(), KernelY()); if (id.x < width && id.y < height) { float2 cur_vec = uv_in[Index(id, uv_mem_w)]; if (!__d_is_invalid_flow(cur_vec)) { float2 splat_upper = d_splat_upper[Index(id, splat_mem_w)]; float2 splat_lower = d_splat_lower[Index(id, splat_mem_w)]; float local_costs[] = { splat_upper.x, splat_upper.y, splat_lower.x, splat_lower.y }; float2 tgt_pos = AddFloat2s(make_float2(id.x, id.y), MultiplyFloat2(cur_vec, time_delta)); for (int nearby = 0; nearby < 4; nearby++) { int2 splat_pos = make_int2( (int)(nearby & 1 ? ceil(tgt_pos.x) : floor(tgt_pos.x)), (int)(nearby & 2 ? ceil(tgt_pos.y) : floor(tgt_pos.y))); if (splat_pos.x >= 0 && splat_pos.x < width && splat_pos.y >= 0 && splat_pos.y < height) { float cost = local_costs[nearby]; if (cost != INVALID_FLOW_VAL && cost == __d_atomic_cas_float(&d_cost_map[Index(splat_pos, cost_mem_w)], cost, INVALID_FLOW_VAL)) { uv_out[Index(splat_pos, uv_mem_w)] = cur_vec; } } } } } }GF_KERNEL _d_flow_fill_holes_joint_with_datacost( GF_PTR(float2) fwd_uv_out, GF_PTR(float2) bwd_uv_out, int uv_mem_w, int width, int height, float time_delta, float local_smoothness, GF_OPENCL_TEXTURE(im1Tex), GF_OPENCL_TEXTURE(im2Tex), GF_OPENCL_TEXTURE(fwdUVTex), GF_OPENCL_TEXTURE(bwdUVTex)) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { float2 fwd_in_uv = __d_read_fwduv_texture(id_x, id_y, GF_GET_TEXTURE(fwdUVTex)); float2 bwd_in_uv = __d_read_bwduv_texture(id_x, id_y, GF_GET_TEXTURE(bwdUVTex)); if (!__d_is_invalid_flow(fwd_in_uv) && !__d_is_invalid_flow(bwd_in_uv)) { fwd_uv_out[id_y*uv_mem_w + id_x] = fwd_in_uv; bwd_uv_out[id_y*uv_mem_w + id_x] = bwd_in_uv; return; } float2 fwd_mean_vec = make_float2(0,0); float2 fwd_vec_candidates[8] = {0}; int fwd_total_valid_neighbor = 0; int fwd_num_candidates = COLLECT_MV_CANDID_NONLOCAL_FWD(id_x,id_y,fwd_vec_candidates,&fwd_mean_vec,&fwd_total_valid_neighbor, GF_GET_TEXTURE(fwdUVTex)); fwd_mean_vec = DivideFloat2(fwd_mean_vec, (float)fwd_total_valid_neighbor); float2 bwd_mean_vec = make_float2(0,0); float2 bwd_vec_candidates[8] = {0}; int bwd_total_valid_neighbor = 0; int bwd_num_candidates = COLLECT_MV_CANDID_NONLOCAL_BWD(id_x,id_y,bwd_vec_candidates,&bwd_mean_vec,&bwd_total_valid_neighbor, GF_GET_TEXTURE(bwdUVTex)); bwd_mean_vec = DivideFloat2(bwd_mean_vec, (float)bwd_total_valid_neighbor); float best_total_cost = 1e8f; float2 best_fwd_vec = fwd_vec_candidates[0]; float2 best_bwd_vec = bwd_vec_candidates[0]; if (fwd_num_candidates>1 || bwd_num_candidates>1) { for (int i=0; i<fwd_num_candidates; i++) { float2 cur_fwd_vec = fwd_vec_candidates[i]; for (int j=0; j<bwd_num_candidates; j++) { float2 cur_bwd_vec = bwd_vec_candidates[j]; float4 pix_diff_f4 = SubtractFloat4s( GF_READTEXTURE(im1Tex, id_x+cur_bwd_vec.x*( time_delta)+0.5f, id_y+cur_bwd_vec.y*( time_delta)+0.5f), GF_READTEXTURE(im2Tex, id_x+cur_fwd_vec.x*(1.f-time_delta)+0.5f, id_y+cur_fwd_vec.y*(1.f-time_delta)+0.5f)); float data_cost = __d_euc_dist(pix_diff_f4); float fwd_smooth_cost = __d_pixmv_smooth_cost(cur_fwd_vec, fwd_mean_vec, local_smoothness); float bwd_smooth_cost = __d_pixmv_smooth_cost(cur_bwd_vec, bwd_mean_vec, local_smoothness); float total_cost = data_cost + fwd_smooth_cost + bwd_smooth_cost; if (total_cost < best_total_cost) { best_total_cost = total_cost; best_fwd_vec = cur_fwd_vec; best_bwd_vec = cur_bwd_vec; } } } } if (__d_is_invalid_flow(best_fwd_vec)) { best_fwd_vec = fwd_in_uv; } if (__d_is_invalid_flow(best_bwd_vec)) { best_bwd_vec = bwd_in_uv; } fwd_uv_out[id_y*uv_mem_w + id_x] = best_fwd_vec; bwd_uv_out[id_y*uv_mem_w + id_x] = best_bwd_vec; } }GF_KERNEL _d_frame_interp_by_two_flow_kernel( GF_PTR(float4) im_out, int im_out_mem_w, GF_PTR(float2) fwd_uv, GF_PTR(float2) bwd_uv, int uv_mem_w, float time_delta, int width, int height, GF_OPENCL_TEXTURE(im1RGBTex), GF_OPENCL_TEXTURE(im2RGBTex)) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { float2 fwd_vec = fwd_uv[id_y*uv_mem_w+id_x]; float2 bwd_vec = bwd_uv[id_y*uv_mem_w+id_x]; float4 pix1 = GF_READTEXTURE(im1RGBTex, id_x+bwd_vec.x+0.5f, id_y+bwd_vec.y+0.5f); float4 pix2 = GF_READTEXTURE(im2RGBTex, id_x+fwd_vec.x+0.5f, id_y+fwd_vec.y+0.5f); im_out[id_y*im_out_mem_w+id_x] = AddFloat4s(MultiplyFloat4(pix1, 1.f-time_delta), MultiplyFloat4(pix2, time_delta)); } }


// buildOptions=-cl-single-precision-constant -cl-fast-relaxed-math -cl-denorms-are-zero -cl-mad-enable -D GF_OPENCL_SUPPORTS_16F
// RUN: %occ-cli %s --cl-options="-I%cwd -I%S -cl-single-precision-constant -cl-fast-relaxed-math -cl-denorms-are-zero -cl-mad-enable -D GF_OPENCL_SUPPORTS_16F" %cfg_path --cl-device=%cl_device 2>&1
