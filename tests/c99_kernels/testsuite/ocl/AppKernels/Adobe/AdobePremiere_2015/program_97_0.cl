#define DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(SrcFormat) \
 DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL_IMPL(SrcFormat, BGRA_4444_32f) \
 DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL_IMPL(BGRA_4444_32f, SrcFormat)

#define DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL_IMPL(SrcFormat, DestFormat) \
 GF_KERNEL PIXEL_FORMAT_CONVERT_KERNEL(SrcFormat, DestFormat)( \
 const GF_PTR(float4) inSrc, \
 int inSrcPitch, \
 DevicePixelFormat inSrcDeviceFormat, \
 GF_PTR(float4) outDest, \
 int inDestPitch, \
 DevicePixelFormat inDestDeviceFormat, \
 int inWidth, \
 int inHeight, \
 int inFlipVertically) \
 { \
 PixelFormatConvert_444_To_444( \
 inSrc, \
 inSrcPitch, \
 kPixelFormat_##SrcFormat, \
 inSrcDeviceFormat, \
 outDest, \
 inDestPitch, \
 kPixelFormat_##DestFormat, \
 inDestDeviceFormat, \
 inWidth, \
 inHeight, \
 inFlipVertically); \
 }
GF_DEVICE_FUNCTION void PixelFormatConvert_444_To_444( const GF_PTR(float4) inSrc, int inSrcPitch, ConversionPixelFormat inSrcPixelFormat, DevicePixelFormat inSrcDeviceFormat, GF_PTR(float4) outDest, int inDestPitch, ConversionPixelFormat inDestPixelFormat, DevicePixelFormat inDestDeviceFormat, int inWidth, int inHeight, int inFlipVertically) { int x = KernelX(); int srcY = KernelY(); if (x < inWidth && srcY < inHeight) { int destY = KernelY(); if (GF_DEVICE_TARGET_OPENCL && inFlipVertically) { destY = inHeight - srcY - 1; } WritePixelFormat_444( ConvertPixel_444_To_444( ReadPixelFormat_444(inSrc, inSrcPitch, inSrcPixelFormat, inSrcDeviceFormat, x, srcY), inSrcPixelFormat, inDestPixelFormat), outDest, inDestPitch, inDestPixelFormat, inDestDeviceFormat, x, destY); } }DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYA_4444_8u) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYP_4444_8u) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYX_4444_8u) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYA_4444_8u_709) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYP_4444_8u_709) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYX_4444_8u_709) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYA_4444_32f) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYP_4444_32f) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYX_4444_32f) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYA_4444_32f_709) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYP_4444_32f_709) DEFINE_444_PIXEL_FORMAT_CONVERT_KERNEL(VUYX_4444_32f_709)


