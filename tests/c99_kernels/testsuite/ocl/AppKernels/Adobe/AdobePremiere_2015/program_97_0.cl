#define PIXEL_FORMAT_CONVERT_KERNEL(from, to) PixelFormatConvert_##from##_To_##to##_Kernel
typedef enum { kAlphaChannel_None = 0x0000, kAlphaChannel_Straight = 0x0001, kAlphaChannel_Premultiplied = 0x0002, kAlphaChannel_Ignore = 0x0004, kAlphaChannel_Bitfield = 0x0007 } AlphaChannel; typedef enum { kChannelBitDepth_8 = 0x0000, kChannelBitDepth_10 = 0x0008, kChannelBitDepth_15 = 0x0010, kChannelBitDepth_16 = 0x0020, kChannelBitDepth_24 = 0x0040, kChannelBitDepth_32 = 0x0080, kChannelBitDepth_Bitfield = 0x00F8 } ChannelBitDepth; typedef enum { kChannelStorageType_UnsignedInt = 0x0000, kChannelStorageType_Float = 0x0100, kChannelStorageType_Bitfield = 0x0100, } ChannelStorageType; typedef enum { kColorSpace_RGB = 0x0000, kColorSpace_YUV = 0x0200, kColorSpace_Bitfield = 0x0200, } ColorSpace; typedef enum { kColorGamma_NonLinear = 0x0000, kColorGamma_Linear = 0x0400, kColorGamma_Bitfield = 0x0400, } ColorGamma; typedef enum { kColorCoding_Rec601 = 0x0000, kColorCoding_Rec709 = 0x0800, kColorCoding_Bitfield = 0x0800, } ColorCoding; typedef enum { kColorRange_Full = 0x0000, kColorRange_Limited = 0x1000, kColorRange_Bitfield = 0x1000, } ColorRange; typedef enum { kEndian_Little = 0x0000, kEndian_Big = 0x2000, kEndian_Bitfield = 0x2000, } Endian; typedef enum { kCompressedFormat_Uncompressed = 0x0000000, kCompressedFormat_NTSCDV = 0x0004000, kCompressedFormat_PALDV = 0x0008000, kCompressedFormat_NTSC_DV100_720p = 0x0010000, kCompressedFormat_PAL_DV100_720p = 0x0020000, kCompressedFormat_NTSC_DV100_1080i = 0x0040000, kCompressedFormat_PAL_DV100_1080i = 0x0080000, kCompressedFormat_NTSCDV50 = 0x0100000, kCompressedFormat_PALDV50 = 0x0200000, kCompressedFormat_MPEG2_FieldCoded = 0x0400000, kCompressedFormat_MPEG2_FrameCoded = 0x0800000, kCompressedFormat_MPEG4_FieldCoded = 0x1000000, kCompressedFormat_MPEG4_FrameCoded = 0x2000000, kCompressedFormat_Bitfield = 0x03FFC000, } CompressedFormat; typedef unsigned int ConversionPixelFormat; GF_DEVICE_FUNCTION GF_HOST_FUNCTION ConversionPixelFormat MakeConversionValue( unsigned int inValue, unsigned int inBitfield) { unsigned int lsb = inBitfield ^ (inBitfield & (inBitfield - 1)); return inValue == 0 ? 0 : lsb << (inValue-1); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ConversionPixelFormat SetConversionValue( ConversionPixelFormat inFormat, unsigned int inValue, unsigned int inBitfield) { return (inFormat & ~inBitfield) | MakeConversionValue(inValue, inBitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION AlphaChannel GetAlphaChannel(ConversionPixelFormat inPixelFormat) { return (AlphaChannel)(inPixelFormat & kAlphaChannel_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ChannelBitDepth GetChannelBitDepth(ConversionPixelFormat inPixelFormat) { return (ChannelBitDepth)(inPixelFormat & kChannelBitDepth_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ChannelStorageType GetChannelStorageType(ConversionPixelFormat inPixelFormat) { return (ChannelStorageType)(inPixelFormat & kChannelStorageType_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ColorSpace GetColorSpace(ConversionPixelFormat inPixelFormat) { return (ColorSpace)(inPixelFormat & kColorSpace_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ColorGamma GetColorGamma(ConversionPixelFormat inPixelFormat) { return (ColorGamma)(inPixelFormat & kColorGamma_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ColorCoding GetColorCoding(ConversionPixelFormat inPixelFormat) { return (ColorCoding)(inPixelFormat & kColorCoding_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION ColorRange GetColorRange(ConversionPixelFormat inPixelFormat) { return (ColorRange)(inPixelFormat & kColorRange_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION Endian GetEndian(ConversionPixelFormat inPixelFormat) { return (Endian)(inPixelFormat & kEndian_Bitfield); } GF_DEVICE_FUNCTION GF_HOST_FUNCTION CompressedFormat GetCompressedFormat(ConversionPixelFormat inPixelFormat) { return (CompressedFormat)(inPixelFormat & kCompressedFormat_Bitfield); }
#endif
GF_DEVICE_FUNCTION int MaxUnsignedBitValue( int inX) { return (2 << (inX-1)) - 1; } GF_DEVICE_FUNCTION float MaxDepthValue( ConversionPixelFormat inPixelFormat) { if (GetChannelBitDepth(inPixelFormat) == kChannelBitDepth_8) { return (float)(MaxUnsignedBitValue(8)); } else if (GetChannelBitDepth(inPixelFormat) == kChannelBitDepth_10) { return (float)(MaxUnsignedBitValue(10)); } else if (GetChannelBitDepth(inPixelFormat) == kChannelBitDepth_15) { return (float)(MaxUnsignedBitValue(15) + 1); } else { return 1.0f; } } GF_DEVICE_FUNCTION float DepthScaleValue( ConversionPixelFormat inSrcPixelFormat, ConversionPixelFormat inDestPixelFormat) { return MaxDepthValue(inDestPixelFormat) / MaxDepthValue(inSrcPixelFormat); } GF_DEVICE_FUNCTION bool IsYCbCr( ConversionPixelFormat inPixelFormat) { return GetColorSpace(inPixelFormat) == kColorSpace_YUV && GetChannelStorageType(inPixelFormat) != kChannelStorageType_Float; } GF_DEVICE_FUNCTION float YCbCrOffset( int inIndex, ConversionPixelFormat inPixelFormat) { return GetColorRange(inPixelFormat) != kColorRange_Full ? kYCbCrOffset[inIndex] : kYCbCrFullRangeOffset[inIndex]; } GF_DEVICE_FUNCTION float4 AddAYCbCrOffset( float4 inPixel, ConversionPixelFormat inPixelFormat) { float scale = DepthScaleValue(kChannelBitDepth_8, inPixelFormat); return make_float4( inPixel.x, inPixel.y + YCbCrOffset(0, inPixelFormat) * scale, inPixel.z + YCbCrOffset(1, inPixelFormat) * scale, inPixel.w + YCbCrOffset(2, inPixelFormat) * scale); } GF_DEVICE_FUNCTION float4 SubtractAYCbCrOffset( float4 inPixel, ConversionPixelFormat inPixelFormat) { float scale = DepthScaleValue(kChannelBitDepth_8, inPixelFormat); return make_float4( inPixel.x, inPixel.y - YCbCrOffset(0, inPixelFormat) * scale, inPixel.z - YCbCrOffset(1, inPixelFormat) * scale, inPixel.w - YCbCrOffset(2, inPixelFormat) * scale); } GF_DEVICE_FUNCTION GF_STATIC_CONSTANT_PTR(float) ColorSpaceConvertMatrix( ConversionPixelFormat inSrcPixelFormat, ConversionPixelFormat inDestPixelFormat) { if (GetColorSpace(inSrcPixelFormat) == kColorSpace_RGB) { if (GetChannelStorageType(inSrcPixelFormat) == kChannelStorageType_Float) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetColorCoding(inDestPixelFormat) == kColorCoding_Rec709) { return kRGB32f_To_709YPbPr; } else { return kRGB32f_To_601YPbPr; } } else { if (GetColorCoding(inDestPixelFormat) == kColorCoding_Rec709) { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { } else { return kRGB32f_To_709YCbCr; } } else { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { return kRGB32f_To_601YCbCrFullRange; } else { return kRGB32f_To_601YCbCr; } } } } else { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetColorCoding(inDestPixelFormat) == kColorCoding_Rec709) { } else { } } else { if (GetColorCoding(inDestPixelFormat) == kColorCoding_Rec709) { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { return kRGB8u_To_709YCbCr; } else { } } else { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { return kRGB8u_To_601YCbCrFullRange; } else { return kRGB8u_To_601YCbCr; } } } } } else if (GetColorCoding(inSrcPixelFormat) == kColorCoding_Rec709) { if (GetColorRange(inSrcPixelFormat) == kColorRange_Full) { if (GetColorSpace(inDestPixelFormat) == kColorSpace_RGB) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { return k709YCbCrFullRange_To_RGB32f; } else { } } else { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetColorCoding(inSrcPixelFormat) == kColorCoding_Rec709) { } else { } } else { if (GetColorCoding(inSrcPixelFormat) == kColorCoding_Rec709) { } else { } } } } else { if (GetColorSpace(inDestPixelFormat) == kColorSpace_RGB) { if (GetChannelStorageType(inSrcPixelFormat) == kChannelStorageType_Float) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { return k709YPbPr_To_RGB32f; } else { } } else { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { return k709YCbCr_To_RGB32f; } else { return k709YCbCr_To_RGB8u; } } } else { if (GetChannelStorageType(inSrcPixelFormat) == kChannelStorageType_Float) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { } else { } } else { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { } else { } } } else { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { } else { } } else { if (GetColorRange(inDestPixelFormat) == kColorRange_Full) { } else { return k709YCbCr_To_601YCbCr; } } } } } } else { if (GetColorRange(inSrcPixelFormat) == kColorRange_Full) { if (GetColorSpace(inDestPixelFormat) == kColorSpace_RGB) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { return k601YCbCrFullRange_To_RGB32f; } else { return k601YCbCrFullRange_To_RGB8u; } } else { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetColorCoding(inSrcPixelFormat) == kColorCoding_Rec709) { } else { } } else { if (GetColorCoding(inSrcPixelFormat) == kColorCoding_Rec709) { } else { } } } } else { if (GetColorSpace(inDestPixelFormat) == kColorSpace_RGB) { if (GetChannelStorageType(inSrcPixelFormat) == kChannelStorageType_Float) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { return k601YPbPr_To_RGB32f; } else { } } else { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { return k601YCbCr_To_RGB32f; } else { return k601YCbCr_To_RGB8u; } } } else { if (GetChannelStorageType(inSrcPixelFormat) == kChannelStorageType_Float) { if (GetChannelStorageType(inDestPixelFormat) == kChannelStorageType_Float) { if (GetChannelStorageType(inSrcPixelFormat) == kColorRange_Full) { } else { } } else { if (GetChannelStorageType(inSrcPixelFormat) == kColorRange_Full) { } else { } } } else { if (GetChannel