
#ifndef GFKERNELSUPPORT_KERNELCORE_H
#define GFKERNELSUPPORT_KERNELCORE_H

#define GF_DEVICE_TARGET_CUDA 0

#define GF_DEVICE_TARGET_OPENCL 1

#define GF_DEVICE_TARGET_HOST 0

#define GF_KERNEL __kernel void

#define GF_DEVICE_FUNCTION

#define GF_HOST_FUNCTION

#define GF_CONSTANT(T) __constant T

#define GF_CONSTANT_PTR(T) GF_PTR(T)

#define GF_CUDA_CONSTANT(T, N)

#define GF_OPENCL_CONSTANT(T, N) GF_PTR(T) N

#define GF_GET_CONSTANT(P) P

#define GF_STATIC_CONSTANT_PTR(T) GF_CONSTANT(T*)

#define GF_SHARED(T) __local T

#define GF_SHARED_PTR(T) __local T*

#define GF_CUDA_SHARED_DYNAMIC(T, N)

#define GF_OPENCL_SHARED_DYNAMIC(T, N) GF_SHARED_PTR(T) N

#define GF_PTR(T) __global T*

#define GF_ALIGN(N) __attribute__ ((aligned (N)))

#define GF_FASTMULTIPLY(X, Y) mul24(X, Y)

#define GF_READ2D(I, R, X, Y) (I)[GF_FASTMULTIPLY(Y, R) + (X)]

#define GF_WRITE2D(P, I, R, X, Y) (I)[GF_FASTMULTIPLY(Y, R) + (X)] = (P)

#define GF_TEXTURE(T, N, S) constant sampler_t kSampler_##N = S;
#define GF_NORMALIZED_TEXTURE(T, N, S) constant sampler_t kSampler_##N = S;
#define GF_OPENCL_TEXTURE(N) __read_only image2d_t N

#define GF_GET_TEXTURE(T) T

#define GF_READTEXTURE(I, X, Y) read_imagef(I, kSampler_##I, (float2)(X, Y))

#ifndef make_int2
#define make_int2(X, Y) (int2)(X, Y)
#endif

#ifndef make_float4
#define make_float4(X, Y, Z, W) (float4)(X, Y, Z, W)
#endif

#ifndef make_float3
#define make_float3(X, Y, Z) (float3)(X, Y, Z)
#endif

#ifndef make_float2
#define make_float2(X, Y) (float2)(X, Y)
#endif

#ifndef make_uchar4
#define make_uchar4(X, Y, Z, W) (uchar4)(X, Y, Z, W)
#endif

#ifndef make_ushort4
#define make_ushort4(X, Y, Z, W) (ushort4)(X, Y, Z, W)
#endif

#ifndef make_uint4
#define make_uint4(X, Y, Z, W) (uint4)(X, Y, Z, W)
#endif
GF_DEVICE_FUNCTION int KernelX() { return get_global_id(0); } GF_DEVICE_FUNCTION int KernelY() { return get_global_id(1); } GF_DEVICE_FUNCTION int2 ThreadID() { return make_int2(get_local_id(0), get_local_id(1)); } GF_DEVICE_FUNCTION int2 BlockID() { return make_int2(get_group_id(0), get_group_id(1)); } GF_DEVICE_FUNCTION int2 BlockSize() { return make_int2(get_local_size(0), get_local_size(1)); } GF_DEVICE_FUNCTION float saturate(float inX) { return clamp(inX, 0.0f, 1.0f); } GF_DEVICE_FUNCTION void SyncThreads() { barrier(CLK_LOCAL_MEM_FENCE); }
#endif
GF_DEVICE_FUNCTION float2 AddFloat2s( float2 inValue0, float2 inValue1) { float2 result = { inValue0.x + inValue1.x, inValue0.y + inValue1.y }; return result; } GF_DEVICE_FUNCTION float2 SubtractFloat2s( float2 inValue0, float2 inValue1) { float2 result = { inValue0.x - inValue1.x, inValue0.y - inValue1.y, }; return result; } GF_DEVICE_FUNCTION float2 MultiplyFloat2( float2 inValue, float inScalar) { float2 result = { inValue.x * inScalar, inValue.y * inScalar, }; return result; }GF_DEVICE_FUNCTION float2 DivideFloat2( float2 inValue, float inScalar) { float2 result = { inValue.x / inScalar, inValue.y / inScalar }; return result; }GF_DEVICE_FUNCTION float4 AddFloat4s( float4 inValue0, float4 inValue1) { float4 result = { inValue0.x + inValue1.x, inValue0.y + inValue1.y, inValue0.z + inValue1.z, inValue0.w + inValue1.w }; return result; } GF_DEVICE_FUNCTION float4 SubtractFloat4s( float4 inValue0, float4 inValue1) { float4 result = { inValue0.x - inValue1.x, inValue0.y - inValue1.y, inValue0.z - inValue1.z, inValue0.w - inValue1.w }; return result; } GF_DEVICE_FUNCTION float4 MultiplyFloat4( float4 inValue, float inScalar) { float4 result = { inValue.x * inScalar, inValue.y * inScalar, inValue.z * inScalar, inValue.w * inScalar }; return result; }GF_DEVICE_FUNCTION float4 DivideFloat4( float4 inValue, float inScalar) { float4 result = { inValue.x / inScalar, inValue.y / inScalar, inValue.z / inScalar, inValue.w / inScalar }; return result; }GF_DEVICE_FUNCTION int __max_i( int a, int b) { return (a > b) ? a : b; } GF_DEVICE_FUNCTION int __min_i( int a, int b) { return (a < b) ? a : b; } GF_DEVICE_FUNCTION float __max_f( float a, float b) { return (a > b) ? a : b; } GF_DEVICE_FUNCTION float __min_f( float a, float b) { return (a < b) ? a : b; }
#define BLOCK_DIM_X 16

#define BLOCK_DIM_Y 16

#define RADIUS_Y_1 1

#define RADIUS_X_1 1

#define RADIUS_X_2 2

#define RADIUS_Y_2 2

#define RADIUS_X_3 3

#define RADIUS_Y_3 3

#define RADIUS_X_4 4

#define RADIUS_Y_4 4

#define RADIUS_X_5 5

#define RADIUS_Y_5 5

#define RADIUS_X_6 6

#define RADIUS_Y_6 6

#define RADIUS_X_7 7

#define RADIUS_Y_7 7

#define s2(a, b) temp = a; a = __min_i(a, b); b = __max_i(temp, b);

#define t2(a, b) s2(buf[a], buf[b]);

#define t24(a, b, c, d, e, f, g, h) t2(a, b); t2(c, d); t2(e, f); t2(g, h);

#define t25(a, b, c, d, e, f, g, h, i, j) t24(a, b, c, d, e, f, g, h); t2(i, j);
GF_DEVICE_FUNCTION float __d_base_e_exponential( float val) { return exp(val); }GF_KERNEL _d_gauss_filter_kernel_float4( GF_PTR(float4) d_imgout, int mem_w_out, GF_PTR(float4) d_imgin, int mem_w_in, int width, int height, float sigma_x, float sigma_y, int radius_x, int radius_y) { int id_x = KernelX(); int id_y = KernelY(); if (id_x < width && id_y < height) { sigma_x = sigma_x*sigma_x*2.f; sigma_y = sigma_y*sigma_y*2.f; float4 val = make_float4(0,0,0,0); float sum = 0; for (int dy=-radius_y; dy<=radius_y; dy++) { for (int dx=-radius_x; dx<=radius_x; dx++) { int cy = __max_i(0,__min_i(height-1,id_y+dy)); int cx = __max_i(0,__min_i(width-1,id_x+dx)); float weight = __d_base_e_exponential(-(float)(dy*dy)/sigma_y) * __d_base_e_exponential(-(float)(dx*dx)/sigma_x); val = AddFloat4s(val, MultiplyFloat4(d_imgin[cy*mem_w_in+cx], weight)); sum += weight; } } val = DivideFloat4(val, sum); d_imgout[id_y*mem_w_out + id_x] = val; } }GF_KERNEL _d_gauss_filter_kernel_shmem_float4_1( GF_PTR(float4) d_imgout, int mem_w_out, GF_PTR(float4) d_imgin, int mem_w_in, int width, int height, float sigma_x, float sigma_y) { GF_SHARED(float4) s_data[BLOCK_DIM_Y + RADIUS_Y_1 * 2][BLOCK_DIM_X + RADIUS_X_1 * 2]; int id_x = __min_i(KernelX(), width-1); int id_y = __min_i(KernelY(), height-1); s_data[ThreadID().y + RADIUS_Y_1][ThreadID().x + RADIUS_X_1] = d_imgin[id_y * mem_w_in + id_x]; if (ThreadID().y < RADIUS_Y_1) { int upper_y = id_y - RADIUS_Y_1; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x + RADIUS_X_1] = d_imgin[upper_y * mem_w_in + id_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_1) { int lower_y = id_y + RADIUS_Y_1; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_1 * 2][ThreadID().x + RADIUS_X_1] = d_imgin[lower_y * mem_w_in + id_x]; } if (ThreadID().x < RADIUS_X_1) { int left_x = id_x - RADIUS_X_1; if (left_x < 0) left_x = 0; s_data[ThreadID().y + RADIUS_Y_1][ThreadID().x] = d_imgin[id_y * mem_w_in + left_x]; if (ThreadID().y < RADIUS_Y_1) { int upper_y = id_y - RADIUS_Y_1; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x] = d_imgin[upper_y * mem_w_in + left_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_1) { int lower_y = id_y + RADIUS_Y_1; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_1 * 2][ThreadID().x] = d_imgin[lower_y * mem_w_in + left_x]; } } if (ThreadID().x >= BLOCK_DIM_X - RADIUS_X_1) { int right_x = id_x + RADIUS_X_1; if (right_x >= width) right_x = width-1; s_data[ThreadID().y + RADIUS_Y_1][ThreadID().x + RADIUS_X_1 * 2] = d_imgin[id_y * mem_w_in + right_x]; if (ThreadID().y < RADIUS_Y_1) { int upper_y = id_y - RADIUS_Y_1; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x + RADIUS_X_1 * 2] = d_imgin[upper_y * mem_w_in + right_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_1) { int lower_y = id_y + RADIUS_Y_1; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_1 * 2][ThreadID().x + RADIUS_X_1 * 2] = d_imgin[lower_y * mem_w_in + right_x]; } } SyncThreads(); id_x = KernelX(); id_y = KernelY(); if (id_x < width && id_y < height) { sigma_x = sigma_x * sigma_x * 2.f; sigma_y = sigma_y * sigma_y * 2.f; float4 val = make_float4(0,0,0,0); float sum = 0; for (int dy = -RADIUS_Y_1; dy <= RADIUS_Y_1; dy++) { for (int dx = -RADIUS_X_1; dx <= RADIUS_X_1; dx++) { float weight = __d_base_e_exponential(-(float)(dy * dy) / sigma_y) * __d_base_e_exponential(-(float)(dx * dx) / sigma_x); val = AddFloat4s(val, MultiplyFloat4(s_data[ThreadID().y + RADIUS_Y_1 + dy][ThreadID().x + RADIUS_X_1 + dx], weight)); sum += weight; } } val = DivideFloat4(val, sum); d_imgout[id_y * mem_w_out + id_x] = val; } }GF_KERNEL _d_gauss_filter_kernel_shmem_float4_2( GF_PTR(float4) d_imgout, int mem_w_out, GF_PTR(float4) d_imgin, int mem_w_in, int width, int height, float sigma_x, float sigma_y) { GF_SHARED(float4) s_data[BLOCK_DIM_Y + RADIUS_Y_2 * 2][BLOCK_DIM_X + RADIUS_X_2 * 2]; int id_x = __min_i(KernelX(), width-1); int id_y = __min_i(KernelY(), height-1); s_data[ThreadID().y + RADIUS_Y_2][ThreadID().x + RADIUS_X_2] = d_imgin[id_y * mem_w_in + id_x]; if (ThreadID().y < RADIUS_Y_2) { int upper_y = id_y - RADIUS_Y_2; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x + RADIUS_X_2] = d_imgin[upper_y * mem_w_in + id_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_2) { int lower_y = id_y + RADIUS_Y_2; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_2 * 2][ThreadID().x + RADIUS_X_2] = d_imgin[lower_y * mem_w_in + id_x]; } if (ThreadID().x < RADIUS_X_2) { int left_x = id_x - RADIUS_X_2; if (left_x < 0) left_x = 0; s_data[ThreadID().y + RADIUS_Y_2][ThreadID().x] = d_imgin[id_y * mem_w_in + left_x]; if (ThreadID().y < RADIUS_Y_2) { int upper_y = id_y - RADIUS_Y_2; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x] = d_imgin[upper_y * mem_w_in + left_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_2) { int lower_y = id_y + RADIUS_Y_2; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_2 * 2][ThreadID().x] = d_imgin[lower_y * mem_w_in + left_x]; } } if (ThreadID().x >= BLOCK_DIM_X - RADIUS_X_2) { int right_x = id_x + RADIUS_X_2; if (right_x >= width) right_x = width-1; s_data[ThreadID().y + RADIUS_Y_2][ThreadID().x + RADIUS_X_2 * 2] = d_imgin[id_y * mem_w_in + right_x]; if (ThreadID().y < RADIUS_Y_2) { int upper_y = id_y - RADIUS_Y_2; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x + RADIUS_X_2 * 2] = d_imgin[upper_y * mem_w_in + right_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_2) { int lower_y = id_y + RADIUS_Y_2; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_2 * 2][ThreadID().x + RADIUS_X_2 * 2] = d_imgin[lower_y * mem_w_in + right_x]; } } SyncThreads(); id_x = KernelX(); id_y = KernelY(); if (id_x < width && id_y < height) { sigma_x = sigma_x * sigma_x * 2.f; sigma_y = sigma_y * sigma_y * 2.f; float4 val = make_float4(0,0,0,0); float sum = 0; for (int dy = -RADIUS_Y_2; dy <= RADIUS_Y_2; dy++) { for (int dx = -RADIUS_X_2; dx <= RADIUS_X_2; dx++) { float weight = __d_base_e_exponential(-(float)(dy * dy) / sigma_y) * __d_base_e_exponential(-(float)(dx * dx) / sigma_x); val = AddFloat4s(val, MultiplyFloat4(s_data[ThreadID().y + RADIUS_Y_2 + dy][ThreadID().x + RADIUS_X_2 + dx], weight)); sum += weight; } } val = DivideFloat4(val, sum); d_imgout[id_y * mem_w_out + id_x] = val; } }GF_KERNEL _d_gauss_filter_kernel_shmem_float4_3( GF_PTR(float4) d_imgout, int mem_w_out, GF_PTR(float4) d_imgin, int mem_w_in, int width, int height, float sigma_x, float sigma_y) { GF_SHARED(float4) s_data[BLOCK_DIM_Y + RADIUS_Y_3 * 2][BLOCK_DIM_X + RADIUS_X_3 * 2]; int id_x = __min_i(KernelX(), width-1); int id_y = __min_i(KernelY(), height-1); s_data[ThreadID().y + RADIUS_Y_3][ThreadID().x + RADIUS_X_3] = d_imgin[id_y * mem_w_in + id_x]; if (ThreadID().y < RADIUS_Y_3) { int upper_y = id_y - RADIUS_Y_3; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x + RADIUS_X_3] = d_imgin[upper_y * mem_w_in + id_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_3) { int lower_y = id_y + RADIUS_Y_3; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_3 * 2][ThreadID().x + RADIUS_X_3] = d_imgin[lower_y * mem_w_in + id_x]; } if (ThreadID().x < RADIUS_X_3) { int left_x = id_x - RADIUS_X_3; if (left_x < 0) left_x = 0; s_data[ThreadID().y + RADIUS_Y_3][ThreadID().x] = d_imgin[id_y * mem_w_in + left_x]; if (ThreadID().y < RADIUS_Y_3) { int upper_y = id_y - RADIUS_Y_3; if (upper_y < 0) upper_y = 0; s_data[ThreadID().y][ThreadID().x] = d_imgin[upper_y * mem_w_in + left_x]; } if (ThreadID().y >= BLOCK_DIM_Y - RADIUS_Y_3) { int lower_y = id_y + RADIUS_Y_3; if (lower_y >= height) lower_y = height-1; s_data[ThreadID().y + RADIUS_Y_3 * 2][ThreadID().x] = d_imgin[lower_y * mem_w_in + left_x]; } } if (ThreadID().x >= BLOCK_DIM_X - RADIUS_X_3) { int right_x = id_x + RADIUS_X_3; if (right_x >= width) right_x = width-1; s_data[ThreadID().y + RADIUS_Y_3][ThreadID().x + RAD