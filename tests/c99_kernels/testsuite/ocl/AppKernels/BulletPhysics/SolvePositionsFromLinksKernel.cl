float mydot3(float4 a, float4 b) { return a.x*b.x + a.y*b.y + a.z*b.z; } __kernel __attribute__((reqd_work_group_size(WAVEFRONT_BLOCK_MULTIPLIER*WAVEFRONT_SIZE, 1, 1))) void SolvePositionsFromLinksKernel( const int startWaveInBatch, const int numWaves, const float kst, const float ti, __global int2 *g_wavefrontBatchCountsVertexCounts, __global int *g_vertexAddressesPerWavefront, __global int2 * g_linksVertexIndices, __global float * g_linksMassLSC, __global float * g_linksRestLengthSquared, __global float * g_verticesInverseMass, __global float4 * g_vertexPositions, __local int2 *wavefrontBatchCountsVertexCounts, __local float4 *vertexPositionSharedData, __local float *vertexInverseMassSharedData) { const int laneInWavefront = (get_global_id(0) & (WAVEFRONT_SIZE-1)); const int wavefront = startWaveInBatch + (get_global_id(0) / WAVEFRONT_SIZE); const int firstWavefrontInBlock = startWaveInBatch + get_group_id(0) * WAVEFRONT_BLOCK_MULTIPLIER; const int localWavefront = wavefront - firstWavefrontInBlock; if( wavefront < (startWaveInBatch + numWaves) ) { int2 batchesAndVerticesWithinWavefront = g_wavefrontBatchCountsVertexCounts[wavefront]; int batchesWithinWavefront = batchesAndVerticesWithinWavefront.x; int verticesUsedByWave = batchesAndVerticesWithinWavefront.y; for( int vertex = laneInWavefront; vertex < verticesUsedByWave; vertex+=WAVEFRONT_SIZE ) { int vertexAddress = g_vertexAddressesPerWavefront[wavefront*MAX_NUM_VERTICES_PER_WAVE + vertex]; vertexPositionSharedData[localWavefront*MAX_NUM_VERTICES_PER_WAVE + vertex] = g_vertexPositions[vertexAddress]; vertexInverseMassSharedData[localWavefront*MAX_NUM_VERTICES_PER_WAVE + vertex] = g_verticesInverseMass[vertexAddress]; } barrier(CLK_LOCAL_MEM_FENCE); int baseDataLocationForWave = WAVEFRONT_SIZE * wavefront * MAX_BATCHES_PER_WAVE; int batch = 0; do { int baseDataLocation = baseDataLocationForWave + WAVEFRONT_SIZE * batch; int locationOfValue = baseDataLocation + laneInWavefront; int2 localVertexIndices = g_linksVertexIndices[locationOfValue]; float massLSC = g_linksMassLSC[locationOfValue]; float restLengthSquared = g_linksRestLengthSquared[locationOfValue]; int vertexAddress0 = MAX_NUM_VERTICES_PER_WAVE * localWavefront + localVertexIndices.x; int vertexAddress1 = MAX_NUM_VERTICES_PER_WAVE * localWavefront + localVertexIndices.y; float4 position0 = vertexPositionSharedData[vertexAddress0]; float4 position1 = vertexPositionSharedData[vertexAddress1]; float inverseMass0 = vertexInverseMassSharedData[vertexAddress0]; float inverseMass1 = vertexInverseMassSharedData[vertexAddress1]; float4 del = position1 - position0; float len = mydot3(del, del); float k = 0; if( massLSC > 0.0f ) { k = ((restLengthSquared - len)/(massLSC*(restLengthSquared+len)))*kst; } position0 = position0 - del*(k*inverseMass0); position1 = position1 + del*(k*inverseMass1); barrier(CLK_LOCAL_MEM_FENCE); vertexPositionSharedData[vertexAddress0] = position0; vertexPositionSharedData[vertexAddress1] = position1; barrier(CLK_LOCAL_MEM_FENCE); ++batch; } while( batch < batchesWithinWavefront ); while((++batch)<30) { barrier(CLK_LOCAL_MEM_FENCE); barrier(CLK_LOCAL_MEM_FENCE); } for( int vertex = laneInWavefront; vertex < verticesUsedByWave; vertex+=WAVEFRONT_SIZE ) { int vertexAddress = g_vertexAddressesPerWavefront[wavefront*MAX_NUM_VERTICES_PER_WAVE + vertex]; g_vertexPositions[vertexAddress] = (float4)(vertexPositionSharedData[localWavefront*MAX_NUM_VERTICES_PER_WAVE + vertex].xyz, 0.f); } } else { int iter = 0; barrier(CLK_LOCAL_MEM_FENCE); while( (++iter)<30) { barrier(CLK_LOCAL_MEM_FENCE); barrier(CLK_LOCAL_MEM_FENCE); } } }


// buildOptions=-DGUID_ARG=  -DMAX_NUM_VERTICES_PER_WAVE=192 -DMAX_BATCHES_PER_WAVE=24 -DWAVEFRONT_SIZE=32 -DWAVEFRONT_BLOCK_MULTIPLIER=2 -DBLOCK_SIZE=64
// RUN: %occ-cli %s --cl-options="-I%cwd -I%S -DGUID_ARG=  -DMAX_NUM_VERTICES_PER_WAVE=192 -DMAX_BATCHES_PER_WAVE=24 -DWAVEFRONT_SIZE=32 -DWAVEFRONT_BLOCK_MULTIPLIER=2 -DBLOCK_SIZE=64" %cfg_path --cl-device=%cl_device 2>&1
