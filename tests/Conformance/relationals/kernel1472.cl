  tmp.S01 = shuffle_fn(source[26]).s00;
  vstore3(tmp, 26, dest);
  tmp = (ulong)((ulong)0);
  tmp.s01 = shuffle_fn(source[27]).s11;
  vstore3(tmp, 27, dest);
  tmp = (ulong)((ulong)0);
  tmp.S01 = shuffle_fn(source[28]).S00;
  vstore3(tmp, 28, dest);
  tmp = (ulong)((ulong)0);
  tmp.s21 = shuffle_fn(source[29]).S11;
  vstore3(tmp, 29, dest);
  tmp = (ulong)((ulong)0);
  tmp.S21 = shuffle_fn(source[30]).s10;
