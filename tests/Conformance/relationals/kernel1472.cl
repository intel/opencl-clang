// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ulong2 shuffle_fn(ulong2 source);
ulong2 shuffle_fn(ulong2 source) { return source; }

__kernel void sample_test(__global ulong2 *source, __global ulong *dest) {
  if (get_global_id(0) != 0)
    return;
  // ulong2 src1 /*, src2*/;
  ulong3 tmp;
  tmp = (ulong)((ulong)0);
  tmp.s2 = shuffle_fn(source[0]).S0;
  vstore3(tmp, 0, dest);
  tmp = (ulong)((ulong)0);
  tmp.s1 = shuffle_fn(source[1]).s0;
  vstore3(tmp, 1, dest);
  tmp = (ulong)((ulong)0);
  tmp.s0 = shuffle_fn(source[2]).S0;
  vstore3(tmp, 2, dest);
  tmp = (ulong)((ulong)0);
  tmp.s1 = shuffle_fn(source[3]).S0;
  vstore3(tmp, 3, dest);
  tmp = (ulong)((ulong)0);
  tmp.S1 = shuffle_fn(source[4]).S1;
  vstore3(tmp, 4, dest);
  tmp = (ulong)((ulong)0);
  tmp.S0 = shuffle_fn(source[5]).s1;
  vstore3(tmp, 5, dest);
  tmp = (ulong)((ulong)0);
  tmp.s1 = shuffle_fn(source[6]).S1;
  vstore3(tmp, 6, dest);
  tmp = (ulong)((ulong)0);
  tmp.s2 = shuffle_fn(source[7]).S1;
  vstore3(tmp, 7, dest);
  tmp = (ulong)((ulong)0);
  tmp.S1 = shuffle_fn(source[8]).s0;
  vstore3(tmp, 8, dest);
  tmp = (ulong)((ulong)0);
  tmp.s1 = shuffle_fn(source[9]).S0;
  vstore3(tmp, 9, dest);
  tmp = (ulong)((ulong)0);
  tmp.s2 = shuffle_fn(source[10]).s0;
  vstore3(tmp, 10, dest);
  tmp = (ulong)((ulong)0);
  tmp.s0 = shuffle_fn(source[11]).S1;
  vstore3(tmp, 11, dest);
  tmp = (ulong)((ulong)0);
  tmp.s2 = shuffle_fn(source[12]).S0;
  vstore3(tmp, 12, dest);
  tmp = (ulong)((ulong)0);
  tmp.s1 = shuffle_fn(source[13]).s0;
  vstore3(tmp, 13, dest);
  tmp = (ulong)((ulong)0);
  tmp.s0 = shuffle_fn(source[14]).s1;
  vstore3(tmp, 14, dest);
  tmp = (ulong)((ulong)0);
  tmp.S2 = shuffle_fn(source[15]).S0;
  vstore3(tmp, 15, dest);
  tmp = (ulong)((ulong)0);
  tmp.s20 = shuffle_fn(source[16]).s10;
  vstore3(tmp, 16, dest);
  tmp = (ulong)((ulong)0);
  tmp.S20 = shuffle_fn(source[17]).s01;
  vstore3(tmp, 17, dest);
  tmp = (ulong)((ulong)0);
  tmp.s21 = shuffle_fn(source[18]).S11;
  vstore3(tmp, 18, dest);
  tmp = (ulong)((ulong)0);
  tmp.s12 = shuffle_fn(source[19]).s10;
  vstore3(tmp, 19, dest);
  tmp = (ulong)((ulong)0);
  tmp.S10 = shuffle_fn(source[20]).s01;
  vstore3(tmp, 20, dest);
  tmp = (ulong)((ulong)0);
  tmp.s12 = shuffle_fn(source[21]).s11;
  vstore3(tmp, 21, dest);
  tmp = (ulong)((ulong)0);
  tmp.S02 = shuffle_fn(source[22]).s10;
  vstore3(tmp, 22, dest);
  tmp = (ulong)((ulong)0);
  tmp.S10 = shuffle_fn(source[23]).S01;
  vstore3(tmp, 23, dest);
