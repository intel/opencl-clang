// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
float16 shuffle_fn(float16 source);
float16 shuffle_fn(float16 source) { return source; }

__kernel void sample_test(__global float16 *source, __global float *dest) {
  if (get_global_id(0) != 0)
    return;
  // float16 src1 /*, src2*/;
  float3 tmp;
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[0]).S0;
  vstore3(tmp, 0, dest);
  tmp = (float)((float)0);
  tmp.S1 = shuffle_fn(source[1]).Se;
  vstore3(tmp, 1, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[2]).se;
  vstore3(tmp, 2, dest);
  tmp = (float)((float)0);
  tmp.S0 = shuffle_fn(source[3]).sF;
  vstore3(tmp, 3, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[4]).SF;
  vstore3(tmp, 4, dest);
  tmp = (float)((float)0);
  tmp.s1 = shuffle_fn(source[5]).s4;
  vstore3(tmp, 5, dest);
  tmp = (float)((float)0);
  tmp.s1 = shuffle_fn(source[6]).S4;
  vstore3(tmp, 6, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[7]).S4;
  vstore3(tmp, 7, dest);
  tmp = (float)((float)0);
  tmp.S1 = shuffle_fn(source[8]).Sc;
  vstore3(tmp, 8, dest);
  tmp = (float)((float)0);
  tmp.S1 = shuffle_fn(source[9]).s6;
  vstore3(tmp, 9, dest);
  tmp = (float)((float)0);
  tmp.S2 = shuffle_fn(source[10]).S6;
  vstore3(tmp, 10, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[11]).Sf4;
  vstore3(tmp, 11, dest);
  tmp = (float)((float)0);
  tmp.S10 = shuffle_fn(source[12]).S2a;
  vstore3(tmp, 12, dest);
  tmp = (float)((float)0);
  tmp.S20 = shuffle_fn(source[13]).sFa;
  vstore3(tmp, 13, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[14]).S44;
  vstore3(tmp, 14, dest);
  tmp = (float)((float)0);
  tmp.S02 = shuffle_fn(source[15]).S16;
  vstore3(tmp, 15, dest);
  tmp = (float)((float)0);
  tmp.s01 = shuffle_fn(source[16]).S00;
  vstore3(tmp, 16, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[17]).SDc;
  vstore3(tmp, 17, dest);
  tmp = (float)((float)0);
  tmp.s20 = shuffle_fn(source[18]).s97;
  vstore3(tmp, 18, dest);
  tmp = (float)((float)0);
  tmp.S21 = shuffle_fn(source[19]).Sb5;
  vstore3(tmp, 19, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[20]).s6d;
  vstore3(tmp, 20, dest);
  tmp = (float)((float)0);
  tmp.S01 = shuffle_fn(source[21]).S48;
  vstore3(tmp, 21, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[22]).S0A;
  vstore3(tmp, 22, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[23]).Sd5;
  vstore3(tmp, 23, dest);
  tmp = (float)((float)0);
  tmp.s12 = shuffle_fn(source[24]).s79;
  vstore3(tmp, 24, dest);
  tmp = (float)((float)0);
  tmp.S01 = shuffle_fn(source[25]).SEf;
  vstore3(tmp, 25, dest);
  tmp = (float)((float)0);
  tmp.s01 = shuffle_fn(source[26]).sC7;
  vstore3(tmp, 26, dest);
  tmp = (float)((float)0);
  tmp.S20 = shuffle_fn(source[27]).S64;
  vstore3(tmp, 27, dest);
  tmp = (float)((float)0);
  tmp.s20 = shuffle_fn(source[28]).sd3;
  vstore3(tmp, 28, dest);
  tmp = (float)((float)0);
  tmp.s02 = shuffle_fn(source[29]).s28;
  vstore3(tmp, 29, dest);
  tmp = (float)((float)0);
  tmp.S20 = shuffle_fn(source[30]).s1b;
  vstore3(tmp, 30, dest);
  tmp = (float)((float)0);
  tmp.S02 = shuffle_fn(source[31]).S16;
  vstore3(tmp, 31, dest);
}
