// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
uchar16 shuffle_fn(uchar16 source);
uchar16 shuffle_fn(uchar16 source) { return source; }

__kernel void sample_test(__global uchar16 *source, __global uchar *dest) {
  if (get_global_id(0) != 0)
    return;
  // uchar16 src1 /*, src2*/;
  uchar3 tmp;
  tmp = (uchar)((uchar)0);
  tmp.s1 = shuffle_fn(source[0]).Sa;
  vstore3(tmp, 0, dest);
  tmp = (uchar)((uchar)0);
  tmp.S0 = shuffle_fn(source[1]).sE;
  vstore3(tmp, 1, dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = shuffle_fn(source[2]).s1;
  vstore3(tmp, 2, dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = shuffle_fn(source[3]).s4;
  vstore3(tmp, 3, dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = shuffle_fn(source[4]).sc;
  vstore3(tmp, 4, dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = shuffle_fn(source[5]).s1;
  vstore3(tmp, 5, dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = shuffle_fn(source[6]).Se;
  vstore3(tmp, 6, dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = shuffle_fn(source[7]).sa;
  vstore3(tmp, 7, dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = shuffle_fn(source[8]).S3;
  vstore3(tmp, 8, dest);
  tmp = (uchar)((uchar)0);
  tmp.s1 = shuffle_fn(source[9]).SB;
  vstore3(tmp, 9, dest);
  tmp = (uchar)((uchar)0);
  tmp.s1 = shuffle_fn(source[10]).SD;
  vstore3(tmp, 10, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[11]).S56;
  vstore3(tmp, 11, dest);
  tmp = (uchar)((uchar)0);
  tmp.S20 = shuffle_fn(source[12]).s95;
  vstore3(tmp, 12, dest);
  tmp = (uchar)((uchar)0);
  tmp.S20 = shuffle_fn(source[13]).S28;
  vstore3(tmp, 13, dest);
  tmp = (uchar)((uchar)0);
  tmp.s12 = shuffle_fn(source[14]).sA3;
  vstore3(tmp, 14, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[15]).S84;
  vstore3(tmp, 15, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[16]).SF5;
  vstore3(tmp, 16, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = shuffle_fn(source[17]).s8d;
  vstore3(tmp, 17, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = shuffle_fn(source[18]).Sb6;
  vstore3(tmp, 18, dest);
  tmp = (uchar)((uchar)0);
  tmp.s12 = shuffle_fn(source[19]).S80;
  vstore3(tmp, 19, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = shuffle_fn(source[20]).S74;
  vstore3(tmp, 20, dest);
  tmp = (uchar)((uchar)0);
  tmp.S12 = shuffle_fn(source[21]).S15;
  vstore3(tmp, 21, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[22]).Se8;
  vstore3(tmp, 22, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = shuffle_fn(source[23]).s53;
  vstore3(tmp, 23, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[24]).sCC;
  vstore3(tmp, 24, dest);
  tmp = (uchar)((uchar)0);
  tmp.S12 = shuffle_fn(source[25]).S0B;
  vstore3(tmp, 25, dest);
  tmp = (uchar)((uchar)0);
  tmp.s12 = shuffle_fn(source[26]).s85;
  vstore3(tmp, 26, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[27]).SFf;
  vstore3(tmp, 27, dest);
  tmp = (uchar)((uchar)0);
  tmp.s01 = shuffle_fn(source[28]).SEB;
  vstore3(tmp, 28, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = shuffle_fn(source[29]).S7b;
  vstore3(tmp, 29, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = shuffle_fn(source[30]).s72;
  vstore3(tmp, 30, dest);
  tmp = (uchar)((uchar)0);
  tmp.s12 = shuffle_fn(source[31]).sd5;
  vstore3(tmp, 31, dest);
}
