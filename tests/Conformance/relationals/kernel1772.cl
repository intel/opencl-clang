  tmp.S1 = ((__global uchar16 *)source)[2].sf;
  vstore3(tmp, 15, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = ((__global uchar16 *)source)[3].s0;
  tmp.S0 = ((__global uchar16 *)source)[3].S1;
  vstore3(tmp, 16, (__global uchar *)dest);
