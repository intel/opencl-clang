  tmp.s2 = ((__global uchar16 *)source)[5].S3;
  vstore3(tmp, 27, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = ((__global uchar16 *)source)[5].S6;
  tmp.s0 = ((__global uchar16 *)source)[5].S6;
  vstore3(tmp, 28, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.s1 = ((__global uchar16 *)source)[5].S7;
  tmp.S2 = ((__global uchar16 *)source)[5].S9;
  vstore3(tmp, 29, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = ((__global uchar16 *)source)[5].sB;
