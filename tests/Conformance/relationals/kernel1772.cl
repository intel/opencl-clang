// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
__kernel void sample_test(__global uchar *source, __global uchar *dest) {
  if (get_global_id(0) != 0)
    return;
  // uchar3 src1 /*, src2*/;
  uchar3 tmp;
  tmp = (uchar)((uchar)0);
