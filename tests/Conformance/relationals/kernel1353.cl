  tmp.s10 = shuffle_fn(source[28]).s13;
  vstore3(tmp, 28, dest);
  tmp = (uint)((uint)0);
  tmp.s21 = shuffle_fn(source[29]).s11;
  vstore3(tmp, 29, dest);
  tmp = (uint)((uint)0);
  tmp.s21 = shuffle_fn(source[30]).S12;
  vstore3(tmp, 30, dest);
