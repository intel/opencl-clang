// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ulong2 shuffle_fn(ulong2 source);
ulong2 shuffle_fn(ulong2 source) { return source; }

__kernel void sample_test(__global ulong2 *source, __global ulong2 *dest) {
