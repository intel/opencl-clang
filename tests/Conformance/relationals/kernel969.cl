// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
char2 shuffle_fn(char2 source);
char2 shuffle_fn(char2 source) { return source; }

__kernel void sample_test(__global char2 *source, __global char *dest) {
