  tmp.S10 = shuffle_fn(source[20]).s22;
  dest[20] = tmp;
  tmp = (double2)((double)0);
  tmp.S10 = shuffle_fn(source[21]).s12;
  dest[21] = tmp;
  tmp = (double2)((double)0);
  tmp.s01 = shuffle_fn(source[22]).s11;
  dest[22] = tmp;
  tmp = (double2)((double)0);
