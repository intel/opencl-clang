// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
#pragma OPENCL EXTENSION cl_khr_fp64 : enable
double4 shuffle_fn(double4 source);
double4 shuffle_fn(double4 source) { return source; }

__kernel void sample_test(__global double4 *source, __global double2 *dest) {
  if (get_global_id(0) != 0)
    return;
  // double4 src1 /*, src2*/;
  double2 tmp;
  tmp = (double2)((double)0);
  tmp.s1 = shuffle_fn(source[0]).s0;
  dest[0] = tmp;
  tmp = (double2)((double)0);
  tmp.S1 = shuffle_fn(source[1]).S1;
  dest[1] = tmp;
  tmp = (double2)((double)0);
  tmp.s0 = shuffle_fn(source[2]).S2;
