// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
long2 shuffle_fn(long2 source);
long2 shuffle_fn(long2 source) { return source; }

__kernel void sample_test(__global long2 *source, __global long *dest) {
  if (get_global_id(0) != 0)
    return;
  // long2 src1 /*, src2*/;
  long3 tmp;
  tmp = (long)((long)0);
  tmp.S0 = shuffle_fn(source[0]).S1;
