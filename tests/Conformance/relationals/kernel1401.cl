  vstore3(tmp, 19, dest);
  tmp = (long)((long)0);
  tmp.s01 = shuffle_fn(source[20]).S10;
  vstore3(tmp, 20, dest);
  tmp = (long)((long)0);
  tmp.S10 = shuffle_fn(source[21]).S01;
  vstore3(tmp, 21, dest);
