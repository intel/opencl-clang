// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
#pragma OPENCL EXTENSION cl_khr_fp64 : enable
double8 shuffle_fn(double8 source);
double8 shuffle_fn(double8 source) { return source; }

__kernel void sample_test(__global double8 *source, __global double *dest) {
  if (get_global_id(0) != 0)
    return;
  // double8 src1 /*, src2*/;
  double tmp;
  tmp = (double)((double)0);
