  dest[5] = tmp;
  tmp = (double)((double)0);
  tmp = shuffle_fn(source[6]).sc;
  dest[6] = tmp;
  tmp = (double)((double)0);
  tmp = shuffle_fn(source[7]).s1;
  dest[7] = tmp;
