  vstore3(tmp, 20, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S1 = ((__global double16 *)source)[4].s0;
  tmp.s0 = ((__global double16 *)source)[4].S0;
  vstore3(tmp, 21, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s1 = ((__global double16 *)source)[4].S3;
  tmp.s0 = ((__global double16 *)source)[4].S2;
  vstore3(tmp, 22, (__global double *)dest);
