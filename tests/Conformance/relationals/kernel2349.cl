  vstore3(tmp, 14, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S2 = ((__global double16 *)source)[2].Se;
  tmp.S1 = ((__global double16 *)source)[2].SF;
  vstore3(tmp, 15, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S0 = ((__global double16 *)source)[3].S0;
  tmp.S2 = ((__global double16 *)source)[3].s2;
  vstore3(tmp, 16, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s1 = ((__global double16 *)source)[3].S5;
  tmp.S2 = ((__global double16 *)source)[3].s3;
  vstore3(tmp, 17, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s0 = ((__global double16 *)source)[3].s7;
