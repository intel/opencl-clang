  tmp = (double)((double)0);
  tmp.S0 = ((__global double16 *)source)[1].sd;
  vstore3(tmp, 9, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s0 = ((__global double16 *)source)[1].sf;
  vstore3(tmp, 10, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S1 = ((__global double16 *)source)[2].S3;
  tmp.s2 = ((__global double16 *)source)[2].S3;
  vstore3(tmp, 11, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s1 = ((__global double16 *)source)[2].s5;
  tmp.s2 = ((__global double16 *)source)[2].s5;
  vstore3(tmp, 12, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s1 = ((__global double16 *)source)[2].s9;
  tmp.S2 = ((__global double16 *)source)[2].s8;
  vstore3(tmp, 13, (__global double *)dest);
  tmp = (double)((double)0);
