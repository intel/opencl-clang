  tmp.S1 = ((__global double16 *)source)[5].S0;
  tmp.S2 = ((__global double16 *)source)[5].s0;
  vstore3(tmp, 26, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s2 = ((__global double16 *)source)[5].S2;
  tmp.s1 = ((__global double16 *)source)[5].S2;
  vstore3(tmp, 27, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S1 = ((__global double16 *)source)[5].s4;
  tmp.s0 = ((__global double16 *)source)[5].s4;
  vstore3(tmp, 28, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S0 = ((__global double16 *)source)[5].S7;
  tmp.S2 = ((__global double16 *)source)[5].s7;
  vstore3(tmp, 29, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S2 = ((__global double16 *)source)[5].SB;
  tmp.S0 = ((__global double16 *)source)[5].sc;
  vstore3(tmp, 30, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s0 = ((__global double16 *)source)[5].sf;
  tmp.s1 = ((__global double16 *)source)[5].SF;
  vstore3(tmp, 31, (__global double *)dest);
}
