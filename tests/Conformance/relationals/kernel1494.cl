// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ulong4 shuffle_fn(ulong4 source);
ulong4 shuffle_fn(ulong4 source) { return source; }

__kernel void sample_test(__global ulong4 *source, __global ulong2 *dest) {
