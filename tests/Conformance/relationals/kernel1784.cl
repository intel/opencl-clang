  vstore3(tmp, 25, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = ((__global uchar16 *)source)[6].s9;
  tmp.S1 = ((__global uchar16 *)source)[6].Sa;
  vstore3(tmp, 26, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = ((__global uchar16 *)source)[6].sE;
  tmp.S2 = ((__global uchar16 *)source)[6].SE;
  vstore3(tmp, 27, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = ((__global uchar16 *)source)[7].s2;
  tmp.s2 = ((__global uchar16 *)source)[7].s3;
  vstore3(tmp, 28, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = ((__global uchar16 *)source)[7].s4;
  tmp.s1 = ((__global uchar16 *)source)[7].s5;
  vstore3(tmp, 29, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = ((__global uchar16 *)source)[7].Sb;
  tmp.S0 = ((__global uchar16 *)source)[7].SA;
  vstore3(tmp, 30, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = ((__global uchar16 *)source)[7].SE;
  tmp.s0 = ((__global uchar16 *)source)[7].sc;
  vstore3(tmp, 31, (__global uchar *)dest);
}
