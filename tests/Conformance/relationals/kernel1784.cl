  vstore3(tmp, 13, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = ((__global uchar16 *)source)[3].sa;
  tmp.s0 = ((__global uchar16 *)source)[3].s9;
  vstore3(tmp, 14, (__global uchar *)dest);
