  tmp.s0 = ((__global uchar16 *)source)[3].SF;
  vstore3(tmp, 15, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = ((__global uchar16 *)source)[4].s1;
  tmp.s1 = ((__global uchar16 *)source)[4].S3;
  vstore3(tmp, 16, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
