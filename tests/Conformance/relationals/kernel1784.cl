  vstore3(tmp, 10, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = ((__global uchar16 *)source)[2].se;
  tmp.S0 = ((__global uchar16 *)source)[2].sc;
  vstore3(tmp, 11, (__global uchar *)dest);
  tmp = (uchar)((uchar)0);
  tmp.S0 = ((__global uchar16 *)source)[3].s0;
  tmp.s1 = ((__global uchar16 *)source)[3].S3;
  vstore3(tmp, 12, (__global uchar *)dest);
