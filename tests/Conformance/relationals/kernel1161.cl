  tmp.s0 = shuffle_fn(source[5]).S1;
  vstore3(tmp, 5, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[6]).Sc;
  vstore3(tmp, 6, dest);
  tmp = (short)((short)0);
  tmp.s1 = shuffle_fn(source[7]).S7;
  vstore3(tmp, 7, dest);
  tmp = (short)((short)0);
  tmp.s2 = shuffle_fn(source[8]).SF;
  vstore3(tmp, 8, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[9]).s3;
  vstore3(tmp, 9, dest);
  tmp = (short)((short)0);
  tmp.S2 = shuffle_fn(source[10]).S5;
  vstore3(tmp, 10, dest);
  tmp = (short)((short)0);
  tmp.s21 = shuffle_fn(source[11]).sAC;
  vstore3(tmp, 11, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[12]).Sfa;
  vstore3(tmp, 12, dest);
  tmp = (short)((short)0);
  tmp.S20 = shuffle_fn(source[13]).sCB;
  vstore3(tmp, 13, dest);
  tmp = (short)((short)0);
  tmp.S02 = shuffle_fn(source[14]).s72;
  vstore3(tmp, 14, dest);
  tmp = (short)((short)0);
  tmp.s20 = shuffle_fn(source[15]).Sef;
  vstore3(tmp, 15, dest);
  tmp = (short)((short)0);
  tmp.S10 = shuffle_fn(source[16]).sf7;
  vstore3(tmp, 16, dest);
