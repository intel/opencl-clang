  tmp.S02 = shuffle_fn(source[17]).Saf;
  vstore3(tmp, 17, dest);
  tmp = (short)((short)0);
  tmp.S12 = shuffle_fn(source[18]).sc5;
  vstore3(tmp, 18, dest);
  tmp = (short)((short)0);
  tmp.S01 = shuffle_fn(source[19]).s8d;
  vstore3(tmp, 19, dest);
  tmp = (short)((short)0);
  tmp.s21 = shuffle_fn(source[20]).S37;
  vstore3(tmp, 20, dest);
  tmp = (short)((short)0);
  tmp.S21 = shuffle_fn(source[21]).sbD;
  vstore3(tmp, 21, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[22]).s82;
  vstore3(tmp, 22, dest);
  tmp = (short)((short)0);
  tmp.S12 = shuffle_fn(source[23]).SD9;
