// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
short16 shuffle_fn(short16 source);
short16 shuffle_fn(short16 source) { return source; }

__kernel void sample_test(__global short16 *source, __global short *dest) {
  if (get_global_id(0) != 0)
    return;
  // short16 src1 /*, src2*/;
  short3 tmp;
  tmp = (short)((short)0);
  tmp.S1 = shuffle_fn(source[0]).s8;
  vstore3(tmp, 0, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[1]).s8;
  vstore3(tmp, 1, dest);
  tmp = (short)((short)0);
  tmp.S1 = shuffle_fn(source[2]).s3;
  vstore3(tmp, 2, dest);
  tmp = (short)((short)0);
  tmp.S0 = shuffle_fn(source[3]).sF;
  vstore3(tmp, 3, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[4]).s5;
  vstore3(tmp, 4, dest);
