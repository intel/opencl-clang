// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ulong16 shuffle_fn(ulong16 source);
ulong16 shuffle_fn(ulong16 source) { return source; }

__kernel void sample_test(__global ulong16 *source, __global ulong *dest) {
  if (get_global_id(0) != 0)
    return;
  // ulong16 src1 /*, src2*/;
  ulong3 tmp;
  tmp = (ulong)((ulong)0);
  tmp.s2 = shuffle_fn(source[0]).S9;
  vstore3(tmp, 0, dest);
  tmp = (ulong)((ulong)0);
  tmp.s0 = shuffle_fn(source[1]).sc;
  vstore3(tmp, 1, dest);
  tmp = (ulong)((ulong)0);
  tmp.s1 = shuffle_fn(source[2]).S8;
  vstore3(tmp, 2, dest);
