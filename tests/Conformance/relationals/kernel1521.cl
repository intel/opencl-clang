  tmp.S1 = shuffle_fn(source[9]).S2;
  vstore3(tmp, 9, dest);
  tmp = (ulong)((ulong)0);
  tmp.s2 = shuffle_fn(source[10]).Se;
  vstore3(tmp, 10, dest);
  tmp = (ulong)((ulong)0);
  tmp.s12 = shuffle_fn(source[11]).S19;
  vstore3(tmp, 11, dest);
  tmp = (ulong)((ulong)0);
  tmp.S20 = shuffle_fn(source[12]).S6C;
  vstore3(tmp, 12, dest);
  tmp = (ulong)((ulong)0);
  tmp.S01 = shuffle_fn(source[13]).sC0;
  vstore3(tmp, 13, dest);
