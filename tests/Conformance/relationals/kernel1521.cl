  tmp.S20 = shuffle_fn(source[18]).sf8;
  vstore3(tmp, 18, dest);
  tmp = (ulong)((ulong)0);
  tmp.s20 = shuffle_fn(source[19]).sF9;
  vstore3(tmp, 19, dest);
  tmp = (ulong)((ulong)0);
  tmp.S02 = shuffle_fn(source[20]).S3a;
  vstore3(tmp, 20, dest);
  tmp = (ulong)((ulong)0);
  tmp.s10 = shuffle_fn(source[21]).sF4;
  vstore3(tmp, 21, dest);
