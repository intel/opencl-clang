// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
__kernel void sample_test(__global ushort2 *source, __global ushort *dest) {
  if (get_global_id(0) != 0)
    return;
  // ushort2 src1 /*, src2*/;
  ushort3 tmp;
  tmp = (ushort)((ushort)0);
  tmp.s2 = source[0].s1;
  vstore3(tmp, 0, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = source[1].S0;
  vstore3(tmp, 1, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = source[2].S0;
  vstore3(tmp, 2, dest);
  tmp = (ushort)((ushort)0);
  tmp.S1 = source[3].S0;
  vstore3(tmp, 3, dest);
  tmp = (ushort)((ushort)0);
  tmp.S0 = source[4].s1;
  vstore3(tmp, 4, dest);
  tmp = (ushort)((ushort)0);
  tmp.S0 = source[5].s0;
  vstore3(tmp, 5, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = source[6].s1;
  vstore3(tmp, 6, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = source[7].s1;
  vstore3(tmp, 7, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = source[8].s0;
  vstore3(tmp, 8, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = source[9].s0;
  vstore3(tmp, 9, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = source[10].S1;
  vstore3(tmp, 10, dest);
  tmp = (ushort)((ushort)0);
  tmp.S1 = source[11].s0;
  vstore3(tmp, 11, dest);
  tmp = (ushort)((ushort)0);
  tmp.S0 = source[12].S1;
  vstore3(tmp, 12, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = source[13].S1;
  vstore3(tmp, 13, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = source[14].S1;
  vstore3(tmp, 14, dest);
  tmp = (ushort)((ushort)0);
  tmp.s1 = source[15].s0;
  vstore3(tmp, 15, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = source[16].S00;
  vstore3(tmp, 16, dest);
  tmp = (ushort)((ushort)0);
  tmp.S12 = source[17].S11;
  vstore3(tmp, 17, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = source[18].s11;
  vstore3(tmp, 18, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = source[19].S01;
  vstore3(tmp, 19, dest);
  tmp = (ushort)((ushort)0);
  tmp.s02 = source[20].S11;
  vstore3(tmp, 20, dest);
  tmp = (ushort)((ushort)0);
  tmp.S12 = source[21].S00;
  vstore3(tmp, 21, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = source[22].s00;
  vstore3(tmp, 22, dest);
  tmp = (ushort)((ushort)0);
  tmp.s01 = source[23].s00;
  vstore3(tmp, 23, dest);
  tmp = (ushort)((ushort)0);
  tmp.s01 = source[24].s01;
  vstore3(tmp, 24, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = source[25].S00;
  vstore3(tmp, 25, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = source[26].S00;
  vstore3(tmp, 26, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = source[27].s00;
  vstore3(tmp, 27, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = source[28].S01;
  vstore3(tmp, 28, dest);
  tmp = (ushort)((ushort)0);
  tmp.s01 = source[29].S10;
  vstore3(tmp, 29, dest);
  tmp = (ushort)((ushort)0);
  tmp.S02 = source[30].s01;
  vstore3(tmp, 30, dest);
  tmp = (ushort)((ushort)0);
  tmp.S02 = source[31].s10;
  vstore3(tmp, 31, dest);
}
