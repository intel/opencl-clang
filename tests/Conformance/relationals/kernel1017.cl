  vstore3(tmp, 9, dest);
  tmp = (char)((char)0);
  tmp.s0 = shuffle_fn(source[10]).S2;
  vstore3(tmp, 10, dest);
  tmp = (char)((char)0);
  tmp.s12 = shuffle_fn(source[11]).S19;
  vstore3(tmp, 11, dest);
  tmp = (char)((char)0);
  tmp.S12 = shuffle_fn(source[12]).s54;
  vstore3(tmp, 12, dest);
  tmp = (char)((char)0);
  tmp.S01 = shuffle_fn(source[13]).S84;
  vstore3(tmp, 13, dest);
  tmp = (char)((char)0);
  tmp.s12 = shuffle_fn(source[14]).SAC;
  vstore3(tmp, 14, dest);
  tmp = (char)((char)0);
  tmp.s12 = shuffle_fn(source[15]).SC6;
  vstore3(tmp, 15, dest);
  tmp = (char)((char)0);
  tmp.s02 = shuffle_fn(source[16]).SdF;
  vstore3(tmp, 16, dest);
