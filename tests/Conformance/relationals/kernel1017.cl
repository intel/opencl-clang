// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
char16 shuffle_fn(char16 source);
char16 shuffle_fn(char16 source) { return source; }

__kernel void sample_test(__global char16 *source, __global char *dest) {
  if (get_global_id(0) != 0)
    return;
  // char16 src1 /*, src2*/;
  char3 tmp;
  tmp = (char)((char)0);
  tmp.S2 = shuffle_fn(source[0]).sf;
  vstore3(tmp, 0, dest);
  tmp = (char)((char)0);
  tmp.S2 = shuffle_fn(source[1]).sd;
  vstore3(tmp, 1, dest);
  tmp = (char)((char)0);
  tmp.S2 = shuffle_fn(source[2]).sb;
  vstore3(tmp, 2, dest);
  tmp = (char)((char)0);
  tmp.S2 = shuffle_fn(source[3]).SD;
  vstore3(tmp, 3, dest);
  tmp = (char)((char)0);
  tmp.s0 = shuffle_fn(source[4]).s5;
  vstore3(tmp, 4, dest);
