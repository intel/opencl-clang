  tmp.S10 = shuffle_fn(source[17]).SDE;
  vstore3(tmp, 17, dest);
  tmp = (char)((char)0);
  tmp.S20 = shuffle_fn(source[18]).s07;
  vstore3(tmp, 18, dest);
  tmp = (char)((char)0);
  tmp.S02 = shuffle_fn(source[19]).S48;
  vstore3(tmp, 19, dest);
  tmp = (char)((char)0);
  tmp.s02 = shuffle_fn(source[20]).sdF;
  vstore3(tmp, 20, dest);
  tmp = (char)((char)0);
  tmp.S02 = shuffle_fn(source[21]).SC9;
  vstore3(tmp, 21, dest);
  tmp = (char)((char)0);
  tmp.s20 = shuffle_fn(source[22]).S7D;
  vstore3(tmp, 22, dest);
  tmp = (char)((char)0);
  tmp.s01 = shuffle_fn(source[23]).Sa5;
