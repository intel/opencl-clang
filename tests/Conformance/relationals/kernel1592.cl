// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
float16 shuffle_fn(float16 source);
float16 shuffle_fn(float16 source) { return source; }

__kernel void sample_test(__global float16 *source, __global float *dest) {
  if (get_global_id(0) != 0)
    return;
  // float16 src1 /*, src2*/;
  float3 tmp;
  tmp = (float)((float)0);
  tmp.s1 = shuffle_fn(source[0]).s1;
  vstore3(tmp, 0, dest);
  tmp = (float)((float)0);
  tmp.s1 = shuffle_fn(source[1]).S9;
  vstore3(tmp, 1, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[2]).s0;
  vstore3(tmp, 2, dest);
  tmp = (float)((float)0);
  tmp.s0 = shuffle_fn(source[3]).S4;
  vstore3(tmp, 3, dest);
  tmp = (float)((float)0);
  tmp.S1 = shuffle_fn(source[4]).SC;
  vstore3(tmp, 4, dest);
  tmp = (float)((float)0);
  tmp.S1 = shuffle_fn(source[5]).sB;
  vstore3(tmp, 5, dest);
  tmp = (float)((float)0);
  tmp.s0 = shuffle_fn(source[6]).S7;
  vstore3(tmp, 6, dest);
  tmp = (float)((float)0);
  tmp.s0 = shuffle_fn(source[7]).sb;
  vstore3(tmp, 7, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[8]).sa;
  vstore3(tmp, 8, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[9]).s7;
  vstore3(tmp, 9, dest);
  tmp = (float)((float)0);
  tmp.s1 = shuffle_fn(source[10]).SD;
  vstore3(tmp, 10, dest);
  tmp = (float)((float)0);
  tmp.s12 = shuffle_fn(source[11]).S0C;
  vstore3(tmp, 11, dest);
  tmp = (float)((float)0);
  tmp.S12 = shuffle_fn(source[12]).SE7;
  vstore3(tmp, 12, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[13]).S8b;
  vstore3(tmp, 13, dest);
  tmp = (float)((float)0);
  tmp.S10 = shuffle_fn(source[14]).S61;
  vstore3(tmp, 14, dest);
  tmp = (float)((float)0);
  tmp.S01 = shuffle_fn(source[15]).SFd;
  vstore3(tmp, 15, dest);
  tmp = (float)((float)0);
  tmp.s12 = shuffle_fn(source[16]).s39;
  vstore3(tmp, 16, dest);
  tmp = (float)((float)0);
  tmp.s02 = shuffle_fn(source[17]).sf4;
  vstore3(tmp, 17, dest);
  tmp = (float)((float)0);
  tmp.s20 = shuffle_fn(source[18]).s36;
  vstore3(tmp, 18, dest);
  tmp = (float)((float)0);
  tmp.s20 = shuffle_fn(source[19]).S7c;
  vstore3(tmp, 19, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[20]).Sd4;
  vstore3(tmp, 20, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[21]).sCA;
  vstore3(tmp, 21, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[22]).S3b;
  vstore3(tmp, 22, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[23]).s57;
  vstore3(tmp, 23, dest);
  tmp = (float)((float)0);
  tmp.s12 = shuffle_fn(source[24]).S90;
  vstore3(tmp, 24, dest);
  tmp = (float)((float)0);
  tmp.s02 = shuffle_fn(source[25]).S30;
  vstore3(tmp, 25, dest);
  tmp = (float)((float)0);
  tmp.s01 = shuffle_fn(source[26]).scF;
  vstore3(tmp, 26, dest);
  tmp = (float)((float)0);
  tmp.s12 = shuffle_fn(source[27]).s97;
  vstore3(tmp, 27, dest);
  tmp = (float)((float)0);
  tmp.s10 = shuffle_fn(source[28]).SC5;
  vstore3(tmp, 28, dest);
  tmp = (float)((float)0);
  tmp.S10 = shuffle_fn(source[29]).S50;
  vstore3(tmp, 29, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[30]).s86;
  vstore3(tmp, 30, dest);
  tmp = (float)((float)0);
  tmp.S02 = shuffle_fn(source[31]).SBF;
  vstore3(tmp, 31, dest);
}
