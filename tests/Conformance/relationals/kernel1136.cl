// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
short4 shuffle_fn(short4 source);
short4 shuffle_fn(short4 source) { return source; }

__kernel void sample_test(__global short4 *source, __global short *dest) {
  if (get_global_id(0) != 0)
    return;
  // short4 src1 /*, src2*/;
  short3 tmp;
  tmp = (short)((short)0);
  tmp.S1 = shuffle_fn(source[0]).s1;
  vstore3(tmp, 0, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[1]).S1;
  vstore3(tmp, 1, dest);
  tmp = (short)((short)0);
  tmp.s2 = shuffle_fn(source[2]).s3;
  vstore3(tmp, 2, dest);
  tmp = (short)((short)0);
  tmp.s1 = shuffle_fn(source[3]).S2;
  vstore3(tmp, 3, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[4]).S3;
  vstore3(tmp, 4, dest);
  tmp = (short)((short)0);
  tmp.S2 = shuffle_fn(source[5]).S2;
  vstore3(tmp, 5, dest);
  tmp = (short)((short)0);
  tmp.S1 = shuffle_fn(source[6]).s1;
  vstore3(tmp, 6, dest);
  tmp = (short)((short)0);
  tmp.S1 = shuffle_fn(source[7]).s2;
  vstore3(tmp, 7, dest);
  tmp = (short)((short)0);
  tmp.S2 = shuffle_fn(source[8]).S3;
  vstore3(tmp, 8, dest);
  tmp = (short)((short)0);
  tmp.S1 = shuffle_fn(source[9]).S0;
  vstore3(tmp, 9, dest);
  tmp = (short)((short)0);
  tmp.s0 = shuffle_fn(source[10]).s0;
  vstore3(tmp, 10, dest);
  tmp = (short)((short)0);
  tmp.S01 = shuffle_fn(source[11]).s00;
  vstore3(tmp, 11, dest);
  tmp = (short)((short)0);
  tmp.s10 = shuffle_fn(source[12]).S23;
  vstore3(tmp, 12, dest);
  tmp = (short)((short)0);
  tmp.S12 = shuffle_fn(source[13]).s01;
  vstore3(tmp, 13, dest);
  tmp = (short)((short)0);
  tmp.s01 = shuffle_fn(source[14]).S12;
  vstore3(tmp, 14, dest);
  tmp = (short)((short)0);
  tmp.s12 = shuffle_fn(source[15]).s13;
  vstore3(tmp, 15, dest);
  tmp = (short)((short)0);
  tmp.s01 = shuffle_fn(source[16]).s10;
  vstore3(tmp, 16, dest);
  tmp = (short)((short)0);
  tmp.S10 = shuffle_fn(source[17]).S01;
  vstore3(tmp, 17, dest);
  tmp = (short)((short)0);
  tmp.S02 = shuffle_fn(source[18]).s21;
  vstore3(tmp, 18, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[19]).S00;
  vstore3(tmp, 19, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[20]).S23;
  vstore3(tmp, 20, dest);
  tmp = (short)((short)0);
  tmp.s21 = shuffle_fn(source[21]).S10;
  vstore3(tmp, 21, dest);
  tmp = (short)((short)0);
  tmp.S12 = shuffle_fn(source[22]).S23;
  vstore3(tmp, 22, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[23]).s02;
  vstore3(tmp, 23, dest);
  tmp = (short)((short)0);
  tmp.S20 = shuffle_fn(source[24]).s11;
  vstore3(tmp, 24, dest);
  tmp = (short)((short)0);
  tmp.s12 = shuffle_fn(source[25]).s01;
  vstore3(tmp, 25, dest);
  tmp = (short)((short)0);
  tmp.S21 = shuffle_fn(source[26]).s31;
  vstore3(tmp, 26, dest);
  tmp = (short)((short)0);
  tmp.S20 = shuffle_fn(source[27]).S11;
  vstore3(tmp, 27, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[28]).S12;
  vstore3(tmp, 28, dest);
  tmp = (short)((short)0);
  tmp.S02 = shuffle_fn(source[29]).s02;
  vstore3(tmp, 29, dest);
  tmp = (short)((short)0);
  tmp.s01 = shuffle_fn(source[30]).S12;
  vstore3(tmp, 30, dest);
  tmp = (short)((short)0);
  tmp.s01 = shuffle_fn(source[31]).S30;
  vstore3(tmp, 31, dest);
}
