// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
short8 shuffle_fn(short8 source);
short8 shuffle_fn(short8 source) { return source; }

__kernel void sample_test(__global short8 *source, __global short *dest) {
