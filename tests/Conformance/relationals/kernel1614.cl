  dest[29] = tmp;
  tmp = (double2)((double)0);
  tmp.S01 = shuffle_fn(source[30]).S01;
  dest[30] = tmp;
  tmp = (double2)((double)0);
  tmp.s01 = shuffle_fn(source[31]).S00;
  dest[31] = tmp;
}
