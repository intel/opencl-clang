  tmp.S1 = shuffle_fn(source[7]).s1;
  dest[7] = tmp;
  tmp = (double2)((double)0);
  tmp.s0 = shuffle_fn(source[8]).S1;
  dest[8] = tmp;
  tmp = (double2)((double)0);
  tmp.S1 = shuffle_fn(source[9]).S1;
  dest[9] = tmp;
  tmp = (double2)((double)0);
  tmp.s1 = shuffle_fn(source[10]).S1;
  dest[10] = tmp;
  tmp = (double2)((double)0);
  tmp.s0 = shuffle_fn(source[11]).s0;
  dest[11] = tmp;
  tmp = (double2)((double)0);
  tmp.S0 = shuffle_fn(source[12]).s1;
  dest[12] = tmp;
  tmp = (double2)((double)0);
  tmp.s1 = shuffle_fn(source[13]).S0;
  dest[13] = tmp;
  tmp = (double2)((double)0);
  tmp.S0 = shuffle_fn(source[14]).S1;
  dest[14] = tmp;
  tmp = (double2)((double)0);
  tmp.s0 = shuffle_fn(source[15]).s0;
  dest[15] = tmp;
  tmp = (double2)((double)0);
  tmp.s10 = shuffle_fn(source[16]).S10;
  dest[16] = tmp;
  tmp = (double2)((double)0);
  tmp.s01 = shuffle_fn(source[17]).s00;
  dest[17] = tmp;
  tmp = (double2)((double)0);
  tmp.s10 = shuffle_fn(source[18]).s10;
  dest[18] = tmp;
  tmp = (double2)((double)0);
  tmp.s10 = shuffle_fn(source[19]).s10;
  dest[19] = tmp;
  tmp = (double2)((double)0);
  tmp.s01 = shuffle_fn(source[20]).s11;
  dest[20] = tmp;
  tmp = (double2)((double)0);
  tmp.s01 = shuffle_fn(source[21]).S10;
  dest[21] = tmp;
  tmp = (double2)((double)0);
  tmp.S01 = shuffle_fn(source[22]).S10;
  dest[22] = tmp;
  tmp = (double2)((double)0);
  tmp.S01 = shuffle_fn(source[23]).s01;
  dest[23] = tmp;
  tmp = (double2)((double)0);
  tmp.s01 = shuffle_fn(source[24]).S10;
