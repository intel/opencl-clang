// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
#pragma OPENCL EXTENSION cl_khr_fp64 : enable
double2 shuffle_fn(double2 source);
double2 shuffle_fn(double2 source) { return source; }

__kernel void sample_test(__global double2 *source, __global double2 *dest) {
  if (get_global_id(0) != 0)
    return;
  // double2 src1 /*, src2*/;
  double2 tmp;
  tmp = (double2)((double)0);
  tmp.S1 = shuffle_fn(source[0]).s1;
  dest[0] = tmp;
  tmp = (double2)((double)0);
  tmp.S0 = shuffle_fn(source[1]).s1;
  dest[1] = tmp;
  tmp = (double2)((double)0);
  tmp.s0 = shuffle_fn(source[2]).s0;
  dest[2] = tmp;
  tmp = (double2)((double)0);
  tmp.s1 = shuffle_fn(source[3]).S0;
  dest[3] = tmp;
  tmp = (double2)((double)0);
  tmp.s0 = shuffle_fn(source[4]).S0;
  dest[4] = tmp;
  tmp = (double2)((double)0);
  tmp.S0 = shuffle_fn(source[5]).s0;
  dest[5] = tmp;
  tmp = (double2)((double)0);
  tmp.S1 = shuffle_fn(source[6]).S1;
  dest[6] = tmp;
