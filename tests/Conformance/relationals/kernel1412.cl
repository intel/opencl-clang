// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
long3 shuffle_fn(long3 source);
long3 shuffle_fn(long3 source) { return source; }

__kernel void sample_test(__global long *source, __global long *dest) {
  if (get_global_id(0) != 0)
    return;
  // long3 src1 /*, src2*/;
  long3 tmp;
  tmp = (long)((long)0);
  tmp.s0 = shuffle_fn(vload3(0, source)).S2;
  vstore3(tmp, 0, dest);
  tmp = (long)((long)0);
  tmp.S0 = shuffle_fn(vload3(1, source)).S0;
  vstore3(tmp, 1, dest);
  tmp = (long)((long)0);
