  vstore3(tmp, 10, dest);
  tmp = (long)((long)0);
  tmp.S10 = shuffle_fn(vload3(11, source)).s11;
  vstore3(tmp, 11, dest);
  tmp = (long)((long)0);
  tmp.s20 = shuffle_fn(vload3(12, source)).s00;
  vstore3(tmp, 12, dest);
  tmp = (long)((long)0);
  tmp.S21 = shuffle_fn(vload3(13, source)).S02;
  vstore3(tmp, 13, dest);
