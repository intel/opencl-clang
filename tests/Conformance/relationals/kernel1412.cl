  tmp.s20 = shuffle_fn(vload3(17, source)).S20;
  vstore3(tmp, 17, dest);
  tmp = (long)((long)0);
  tmp.s12 = shuffle_fn(vload3(18, source)).S12;
  vstore3(tmp, 18, dest);
  tmp = (long)((long)0);
  tmp.S21 = shuffle_fn(vload3(19, source)).s10;
  vstore3(tmp, 19, dest);
  tmp = (long)((long)0);
  tmp.S21 = shuffle_fn(vload3(20, source)).s10;
  vstore3(tmp, 20, dest);
