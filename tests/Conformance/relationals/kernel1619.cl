  tmp.s2 = shuffle_fn(source[12]).s0;
  dest[12] = tmp;
  tmp = (double4)((double)0);
  tmp.s1 = shuffle_fn(source[13]).s0;
  dest[13] = tmp;
  tmp = (double4)((double)0);
  tmp.S0 = shuffle_fn(source[14]).s0;
  dest[14] = tmp;
