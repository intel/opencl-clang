  tmp = (double4)((double)0);
  tmp.s30 = shuffle_fn(source[20]).S11;
  dest[20] = tmp;
  tmp = (double4)((double)0);
  tmp.S12 = shuffle_fn(source[21]).s11;
  dest[21] = tmp;
  tmp = (double4)((double)0);
  tmp.S13 = shuffle_fn(source[22]).S00;
  dest[22] = tmp;
  tmp = (double4)((double)0);
  tmp.s01 = shuffle_fn(source[23]).s00;
