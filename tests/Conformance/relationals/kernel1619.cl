// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
#pragma OPENCL EXTENSION cl_khr_fp64 : enable
double2 shuffle_fn(double2 source);
double2 shuffle_fn(double2 source) { return source; }

__kernel void sample_test(__global double2 *source, __global double4 *dest) {
  if (get_global_id(0) != 0)
    return;
  // double2 src1 /*, src2*/;
  double4 tmp;
  tmp = (double4)((double)0);
  tmp.S1 = shuffle_fn(source[0]).S0;
  dest[0] = tmp;
  tmp = (double4)((double)0);
  tmp.s2 = shuffle_fn(source[1]).s1;
  dest[1] = tmp;
  tmp = (double4)((double)0);
  tmp.s1 = shuffle_fn(source[2]).S0;
