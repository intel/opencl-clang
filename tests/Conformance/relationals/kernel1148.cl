// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
short8 shuffle_fn(short8 source);
short8 shuffle_fn(short8 source) { return source; }

__kernel void sample_test(__global short8 *source, __global short *dest) {
  if (get_global_id(0) != 0)
    return;
  // short8 src1 /*, src2*/;
  short3 tmp;
  tmp = (short)((short)0);
  tmp.s2 = shuffle_fn(source[0]).s2;
  vstore3(tmp, 0, dest);
  tmp = (short)((short)0);
  tmp.S2 = shuffle_fn(source[1]).S2;
  vstore3(tmp, 1, dest);
  tmp = (short)((short)0);
  tmp.s1 = shuffle_fn(source[2]).s0;
  vstore3(tmp, 2, dest);
