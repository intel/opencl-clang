  tmp.S21 = shuffle_fn(source[11]).s26;
  vstore3(tmp, 11, dest);
  tmp = (short)((short)0);
  tmp.S01 = shuffle_fn(source[12]).S61;
  vstore3(tmp, 12, dest);
  tmp = (short)((short)0);
  tmp.S12 = shuffle_fn(source[13]).S15;
  vstore3(tmp, 13, dest);
