  vstore3(tmp, 19, dest);
  tmp = (short)((short)0);
  tmp.S02 = shuffle_fn(source[20]).S05;
  vstore3(tmp, 20, dest);
  tmp = (short)((short)0);
  tmp.s12 = shuffle_fn(source[21]).s27;
  vstore3(tmp, 21, dest);
  tmp = (short)((short)0);
  tmp.s10 = shuffle_fn(source[22]).S37;
  vstore3(tmp, 22, dest);
