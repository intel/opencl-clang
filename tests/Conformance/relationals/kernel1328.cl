// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
uint2 shuffle_fn(uint2 source);
uint2 shuffle_fn(uint2 source) { return source; }

__kernel void sample_test(__global uint2 *source, __global uint *dest) {
  if (get_global_id(0) != 0)
    return;
  // uint2 src1 /*, src2*/;
  uint3 tmp;
  tmp = (uint)((uint)0);
  tmp.s1 = shuffle_fn(source[0]).S0;
  vstore3(tmp, 0, dest);
  tmp = (uint)((uint)0);
  tmp.s2 = shuffle_fn(source[1]).s0;
  vstore3(tmp, 1, dest);
  tmp = (uint)((uint)0);
  tmp.S0 = shuffle_fn(source[2]).s1;
  vstore3(tmp, 2, dest);
  tmp = (uint)((uint)0);
  tmp.S0 = shuffle_fn(source[3]).s0;
  vstore3(tmp, 3, dest);
  tmp = (uint)((uint)0);
  tmp.S1 = shuffle_fn(source[4]).S1;
  vstore3(tmp, 4, dest);
  tmp = (uint)((uint)0);
  tmp.s0 = shuffle_fn(source[5]).s1;
  vstore3(tmp, 5, dest);
  tmp = (uint)((uint)0);
