  vstore3(tmp, 9, dest);
  tmp = (uint)((uint)0);
  tmp.S2 = shuffle_fn(source[10]).S1;
  vstore3(tmp, 10, dest);
  tmp = (uint)((uint)0);
  tmp.S1 = shuffle_fn(source[11]).s0;
  vstore3(tmp, 11, dest);
  tmp = (uint)((uint)0);
  tmp.s0 = shuffle_fn(source[12]).s0;
  vstore3(tmp, 12, dest);
  tmp = (uint)((uint)0);
  tmp.S1 = shuffle_fn(source[13]).s1;
  vstore3(tmp, 13, dest);
  tmp = (uint)((uint)0);
  tmp.s2 = shuffle_fn(source[14]).S1;
  vstore3(tmp, 14, dest);
