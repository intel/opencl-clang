  tmp.S1 = shuffle_fn(source[15]).s0;
  vstore3(tmp, 15, dest);
  tmp = (uint)((uint)0);
  tmp.s01 = shuffle_fn(source[16]).s10;
  vstore3(tmp, 16, dest);
  tmp = (uint)((uint)0);
  tmp.S20 = shuffle_fn(source[17]).S11;
  vstore3(tmp, 17, dest);
  tmp = (uint)((uint)0);
  tmp.s02 = shuffle_fn(source[18]).S10;
  vstore3(tmp, 18, dest);
  tmp = (uint)((uint)0);
  tmp.s01 = shuffle_fn(source[19]).s01;
  vstore3(tmp, 19, dest);
  tmp = (uint)((uint)0);
  tmp.S10 = shuffle_fn(source[20]).S00;
  vstore3(tmp, 20, dest);
  tmp = (uint)((uint)0);
  tmp.S21 = shuffle_fn(source[21]).s11;
  vstore3(tmp, 21, dest);
  tmp = (uint)((uint)0);
  tmp.S10 = shuffle_fn(source[22]).S10;
  vstore3(tmp, 22, dest);
  tmp = (uint)((uint)0);
  tmp.s12 = shuffle_fn(source[23]).S10;
