  tmp.S12 = shuffle_fn(source[26]).S71;
  vstore3(tmp, 26, dest);
  tmp = (ushort)((ushort)0);
  tmp.s01 = shuffle_fn(source[27]).s65;
  vstore3(tmp, 27, dest);
  tmp = (ushort)((ushort)0);
  tmp.S12 = shuffle_fn(source[28]).S32;
  vstore3(tmp, 28, dest);
