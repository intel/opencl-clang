// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ushort8 shuffle_fn(ushort8 source);
ushort8 shuffle_fn(ushort8 source) { return source; }

__kernel void sample_test(__global ushort8 *source, __global ushort *dest) {
  if (get_global_id(0) != 0)
    return;
  // ushort8 src1 /*, src2*/;
  ushort3 tmp;
  tmp = (ushort)((ushort)0);
  tmp.S0 = shuffle_fn(source[0]).S1;
  vstore3(tmp, 0, dest);
  tmp = (ushort)((ushort)0);
  tmp.s1 = shuffle_fn(source[1]).s3;
  vstore3(tmp, 1, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = shuffle_fn(source[2]).S2;
  vstore3(tmp, 2, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = shuffle_fn(source[3]).s5;
  vstore3(tmp, 3, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = shuffle_fn(source[4]).S7;
  vstore3(tmp, 4, dest);
  tmp = (ushort)((ushort)0);
  tmp.S0 = shuffle_fn(source[5]).s6;
  vstore3(tmp, 5, dest);
  tmp = (ushort)((ushort)0);
  tmp.s1 = shuffle_fn(source[6]).S3;
  vstore3(tmp, 6, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[7]).S5;
  vstore3(tmp, 7, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[8]).s7;
  vstore3(tmp, 8, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[9]).S0;
  vstore3(tmp, 9, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[10]).S0;
  vstore3(tmp, 10, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = shuffle_fn(source[11]).S65;
  vstore3(tmp, 11, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = shuffle_fn(source[12]).s26;
  vstore3(tmp, 12, dest);
  tmp = (ushort)((ushort)0);
  tmp.S01 = shuffle_fn(source[13]).S27;
  vstore3(tmp, 13, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = shuffle_fn(source[14]).S31;
  vstore3(tmp, 14, dest);
  tmp = (ushort)((ushort)0);
  tmp.s20 = shuffle_fn(source[15]).s13;
  vstore3(tmp, 15, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = shuffle_fn(source[16]).S65;
  vstore3(tmp, 16, dest);
  tmp = (ushort)((ushort)0);
  tmp.S12 = shuffle_fn(source[17]).S03;
  vstore3(tmp, 17, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = shuffle_fn(source[18]).s42;
  vstore3(tmp, 18, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = shuffle_fn(source[19]).s00;
  vstore3(tmp, 19, dest);
  tmp = (ushort)((ushort)0);
  tmp.s21 = shuffle_fn(source[20]).s25;
  vstore3(tmp, 20, dest);
  tmp = (ushort)((ushort)0);
  tmp.s02 = shuffle_fn(source[21]).S50;
  vstore3(tmp, 21, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = shuffle_fn(source[22]).S01;
  vstore3(tmp, 22, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = shuffle_fn(source[23]).s02;
  vstore3(tmp, 23, dest);
