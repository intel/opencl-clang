// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
__kernel void sample_test(__global float2 *source, __global float *dest) {
  if (get_global_id(0) != 0)
    return;
  // float2 src1 /*, src2*/;
  float3 tmp;
  tmp = (float)((float)0);
  tmp.s1 = source[0].S1;
  vstore3(tmp, 0, dest);
  tmp = (float)((float)0);
  tmp.s1 = source[1].S1;
  vstore3(tmp, 1, dest);
  tmp = (float)((float)0);
  tmp.S1 = source[2].S0;
  vstore3(tmp, 2, dest);
