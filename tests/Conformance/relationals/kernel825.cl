  vstore3(tmp, 14, dest);
  tmp = (float)((float)0);
  tmp.S0 = source[15].s1;
  vstore3(tmp, 15, dest);
  tmp = (float)((float)0);
  tmp.S21 = source[16].s01;
  vstore3(tmp, 16, dest);
  tmp = (float)((float)0);
  tmp.s01 = source[17].s01;
  vstore3(tmp, 17, dest);
