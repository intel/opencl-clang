  tmp.s10 = source[21].s11;
  vstore3(tmp, 21, dest);
  tmp = (float)((float)0);
  tmp.s01 = source[22].s11;
  vstore3(tmp, 22, dest);
  tmp = (float)((float)0);
  tmp.S20 = source[23].s01;
  vstore3(tmp, 23, dest);
  tmp = (float)((float)0);
  tmp.s02 = source[24].S01;
  vstore3(tmp, 24, dest);
