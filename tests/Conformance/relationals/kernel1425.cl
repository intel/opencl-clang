  tmp.S20 = shuffle_fn(source[18]).s12;
  vstore3(tmp, 18, dest);
  tmp = (long)((long)0);
  tmp.s12 = shuffle_fn(source[19]).s03;
  vstore3(tmp, 19, dest);
  tmp = (long)((long)0);
  tmp.s01 = shuffle_fn(source[20]).s10;
  vstore3(tmp, 20, dest);
  tmp = (long)((long)0);
  tmp.S12 = shuffle_fn(source[21]).S31;
  vstore3(tmp, 21, dest);
  tmp = (long)((long)0);
  tmp.S21 = shuffle_fn(source[22]).s01;
  vstore3(tmp, 22, dest);
