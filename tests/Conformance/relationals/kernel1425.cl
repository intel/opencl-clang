  tmp.s0 = shuffle_fn(source[9]).S0;
  vstore3(tmp, 9, dest);
  tmp = (long)((long)0);
  tmp.S0 = shuffle_fn(source[10]).S1;
  vstore3(tmp, 10, dest);
  tmp = (long)((long)0);
  tmp.s01 = shuffle_fn(source[11]).S22;
  vstore3(tmp, 11, dest);
  tmp = (long)((long)0);
  tmp.s12 = shuffle_fn(source[12]).s22;
  vstore3(tmp, 12, dest);
  tmp = (long)((long)0);
  tmp.S01 = shuffle_fn(source[13]).S11;
  vstore3(tmp, 13, dest);
  tmp = (long)((long)0);
  tmp.S01 = shuffle_fn(source[14]).s30;
  vstore3(tmp, 14, dest);
  tmp = (long)((long)0);
  tmp.S01 = shuffle_fn(source[15]).S12;
  vstore3(tmp, 15, dest);
  tmp = (long)((long)0);
  tmp.S20 = shuffle_fn(source[16]).S33;
  vstore3(tmp, 16, dest);
