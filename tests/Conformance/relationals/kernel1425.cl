// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
long4 shuffle_fn(long4 source);
long4 shuffle_fn(long4 source) { return source; }

__kernel void sample_test(__global long4 *source, __global long *dest) {
  if (get_global_id(0) != 0)
    return;
  // long4 src1 /*, src2*/;
  long3 tmp;
  tmp = (long)((long)0);
  tmp.s2 = shuffle_fn(source[0]).s0;
  vstore3(tmp, 0, dest);
  tmp = (long)((long)0);
  tmp.s2 = shuffle_fn(source[1]).s1;
  vstore3(tmp, 1, dest);
  tmp = (long)((long)0);
  tmp.s2 = shuffle_fn(source[2]).s0;
  vstore3(tmp, 2, dest);
  tmp = (long)((long)0);
  tmp.S0 = shuffle_fn(source[3]).S2;
  vstore3(tmp, 3, dest);
  tmp = (long)((long)0);
  tmp.s2 = shuffle_fn(source[4]).s0;
  vstore3(tmp, 4, dest);
