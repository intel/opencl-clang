// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
float4 shuffle_fn(float4 source);
float4 shuffle_fn(float4 source) { return source; }

__kernel void sample_test(__global float4 *source, __global float *dest) {
