// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
__kernel void sample_test(__global uchar4 *source, __global uchar *dest) {
  if (get_global_id(0) != 0)
    return;
  // uchar4 src1 /*, src2*/;
  uchar3 tmp;
  tmp = (uchar)((uchar)0);
  tmp.S1 = source[0].s1;
  vstore3(tmp, 0, dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = source[1].S1;
  vstore3(tmp, 1, dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = source[2].S3;
  vstore3(tmp, 2, dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = source[3].S0;
  vstore3(tmp, 3, dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = source[4].S2;
  vstore3(tmp, 4, dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = source[5].s2;
  vstore3(tmp, 5, dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = source[6].s0;
  vstore3(tmp, 6, dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = source[7].s2;
  vstore3(tmp, 7, dest);
  tmp = (uchar)((uchar)0);
  tmp.S1 = source[8].s1;
  vstore3(tmp, 8, dest);
  tmp = (uchar)((uchar)0);
  tmp.s1 = source[9].S0;
  vstore3(tmp, 9, dest);
  tmp = (uchar)((uchar)0);
  tmp.S0 = source[10].s1;
  vstore3(tmp, 10, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = source[11].S20;
  vstore3(tmp, 11, dest);
  tmp = (uchar)((uchar)0);
  tmp.s01 = source[12].S03;
  vstore3(tmp, 12, dest);
  tmp = (uchar)((uchar)0);
  tmp.s01 = source[13].S00;
  vstore3(tmp, 13, dest);
  tmp = (uchar)((uchar)0);
  tmp.S20 = source[14].S21;
  vstore3(tmp, 14, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = source[15].S13;
  vstore3(tmp, 15, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = source[16].s13;
  vstore3(tmp, 16, dest);
  tmp = (uchar)((uchar)0);
  tmp.S20 = source[17].s10;
  vstore3(tmp, 17, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = source[18].S31;
  vstore3(tmp, 18, dest);
  tmp = (uchar)((uchar)0);
  tmp.S12 = source[19].s02;
  vstore3(tmp, 19, dest);
  tmp = (uchar)((uchar)0);
  tmp.s01 = source[20].s30;
  vstore3(tmp, 20, dest);
  tmp = (uchar)((uchar)0);
  tmp.S20 = source[21].S03;
  vstore3(tmp, 21, dest);
  tmp = (uchar)((uchar)0);
  tmp.S12 = source[22].S13;
  vstore3(tmp, 22, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = source[23].S03;
  vstore3(tmp, 23, dest);
  tmp = (uchar)((uchar)0);
  tmp.s02 = source[24].S32;
  vstore3(tmp, 24, dest);
  tmp = (uchar)((uchar)0);
  tmp.s20 = source[25].S32;
  vstore3(tmp, 25, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = source[26].S12;
  vstore3(tmp, 26, dest);
  tmp = (uchar)((uchar)0);
  tmp.S02 = source[27].s22;
  vstore3(tmp, 27, dest);
  tmp = (uchar)((uchar)0);
  tmp.s02 = source[28].S23;
  vstore3(tmp, 28, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = source[29].S01;
  vstore3(tmp, 29, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = source[30].s32;
  vstore3(tmp, 30, dest);
