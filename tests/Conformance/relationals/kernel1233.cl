// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ushort16 shuffle_fn(ushort16 source);
ushort16 shuffle_fn(ushort16 source) { return source; }

__kernel void sample_test(__global ushort16 *source, __global ushort *dest) {
  if (get_global_id(0) != 0)
    return;
  // ushort16 src1 /*, src2*/;
  ushort3 tmp;
  tmp = (ushort)((ushort)0);
  tmp.S2 = shuffle_fn(source[0]).S5;
  vstore3(tmp, 0, dest);
  tmp = (ushort)((ushort)0);
  tmp.S0 = shuffle_fn(source[1]).S6;
  vstore3(tmp, 1, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = shuffle_fn(source[2]).sA;
  vstore3(tmp, 2, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = shuffle_fn(source[3]).s9;
  vstore3(tmp, 3, dest);
  tmp = (ushort)((ushort)0);
  tmp.s2 = shuffle_fn(source[4]).S8;
  vstore3(tmp, 4, dest);
