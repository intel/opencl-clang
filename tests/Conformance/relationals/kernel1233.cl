  tmp = (ushort)((ushort)0);
  tmp.S2 = shuffle_fn(source[9]).s2;
  vstore3(tmp, 9, dest);
  tmp = (ushort)((ushort)0);
  tmp.S1 = shuffle_fn(source[10]).s3;
  vstore3(tmp, 10, dest);
  tmp = (ushort)((ushort)0);
  tmp.s10 = shuffle_fn(source[11]).sc5;
  vstore3(tmp, 11, dest);
  tmp = (ushort)((ushort)0);
  tmp.s01 = shuffle_fn(source[12]).S4c;
  vstore3(tmp, 12, dest);
  tmp = (ushort)((ushort)0);
  tmp.S12 = shuffle_fn(source[13]).sD2;
  vstore3(tmp, 13, dest);
  tmp = (ushort)((ushort)0);
  tmp.s02 = shuffle_fn(source[14]).SDA;
  vstore3(tmp, 14, dest);
  tmp = (ushort)((ushort)0);
  tmp.S01 = shuffle_fn(source[15]).s56;
  vstore3(tmp, 15, dest);
