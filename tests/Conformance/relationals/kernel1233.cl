  tmp.S2 = shuffle_fn(source[5]).s6;
  vstore3(tmp, 5, dest);
  tmp = (ushort)((ushort)0);
  tmp.S1 = shuffle_fn(source[6]).sC;
  vstore3(tmp, 6, dest);
