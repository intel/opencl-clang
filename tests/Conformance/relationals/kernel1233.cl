  tmp.S02 = shuffle_fn(source[16]).SC8;
  vstore3(tmp, 16, dest);
  tmp = (ushort)((ushort)0);
  tmp.S20 = shuffle_fn(source[17]).SC4;
  vstore3(tmp, 17, dest);
  tmp = (ushort)((ushort)0);
  tmp.s21 = shuffle_fn(source[18]).S21;
  vstore3(tmp, 18, dest);
  tmp = (ushort)((ushort)0);
  tmp.s10 = shuffle_fn(source[19]).sBF;
  vstore3(tmp, 19, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = shuffle_fn(source[20]).Sb5;
  vstore3(tmp, 20, dest);
  tmp = (ushort)((ushort)0);
  tmp.s10 = shuffle_fn(source[21]).s8d;
  vstore3(tmp, 21, dest);
  tmp = (ushort)((ushort)0);
  tmp.s20 = shuffle_fn(source[22]).S33;
