  vstore3(tmp, 9, dest);
  tmp = (char)((char)0);
  tmp.s0 = shuffle_fn(source[10]).S3;
  vstore3(tmp, 10, dest);
  tmp = (char)((char)0);
  tmp.S21 = shuffle_fn(source[11]).sFb;
  vstore3(tmp, 11, dest);
  tmp = (char)((char)0);
  tmp.s12 = shuffle_fn(source[12]).s83;
  vstore3(tmp, 12, dest);
