  tmp = (char)((char)0);
  tmp.s02 = shuffle_fn(source[19]).sa5;
  vstore3(tmp, 19, dest);
  tmp = (char)((char)0);
  tmp.s10 = shuffle_fn(source[20]).sc3;
  vstore3(tmp, 20, dest);
  tmp = (char)((char)0);
  tmp.S21 = shuffle_fn(source[21]).SC0;
  vstore3(tmp, 21, dest);
  tmp = (char)((char)0);
  tmp.s01 = shuffle_fn(source[22]).s1F;
  vstore3(tmp, 22, dest);
