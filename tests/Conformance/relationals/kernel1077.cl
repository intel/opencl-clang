// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
uchar8 shuffle_fn(uchar8 source);
uchar8 shuffle_fn(uchar8 source) { return source; }

__kernel void sample_test(__global uchar8 *source, __global uchar *dest) {
  if (get_global_id(0) != 0)
    return;
  // uchar8 src1 /*, src2*/;
  uchar3 tmp;
  tmp = (uchar)((uchar)0);
  tmp.s0 = shuffle_fn(source[0]).S5;
  vstore3(tmp, 0, dest);
  tmp = (uchar)((uchar)0);
  tmp.s0 = shuffle_fn(source[1]).s0;
  vstore3(tmp, 1, dest);
  tmp = (uchar)((uchar)0);
  tmp.S0 = shuffle_fn(source[2]).S3;
  vstore3(tmp, 2, dest);
  tmp = (uchar)((uchar)0);
  tmp.S0 = shuffle_fn(source[3]).s0;
  vstore3(tmp, 3, dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = shuffle_fn(source[4]).s1;
  vstore3(tmp, 4, dest);
  tmp = (uchar)((uchar)0);
  tmp.s1 = shuffle_fn(source[5]).S1;
  vstore3(tmp, 5, dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = shuffle_fn(source[6]).S1;
  vstore3(tmp, 6, dest);
  tmp = (uchar)((uchar)0);
  tmp.S2 = shuffle_fn(source[7]).s0;
  vstore3(tmp, 7, dest);
  tmp = (uchar)((uchar)0);
  tmp.s1 = shuffle_fn(source[8]).s4;
  vstore3(tmp, 8, dest);
  tmp = (uchar)((uchar)0);
  tmp.s2 = shuffle_fn(source[9]).s4;
  vstore3(tmp, 9, dest);
  tmp = (uchar)((uchar)0);
  tmp.S0 = shuffle_fn(source[10]).s7;
  vstore3(tmp, 10, dest);
  tmp = (uchar)((uchar)0);
  tmp.s01 = shuffle_fn(source[11]).s61;
  vstore3(tmp, 11, dest);
  tmp = (uchar)((uchar)0);
  tmp.S02 = shuffle_fn(source[12]).s12;
  vstore3(tmp, 12, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = shuffle_fn(source[13]).S25;
  vstore3(tmp, 13, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = shuffle_fn(source[14]).s13;
  vstore3(tmp, 14, dest);
  tmp = (uchar)((uchar)0);
  tmp.S12 = shuffle_fn(source[15]).s22;
  vstore3(tmp, 15, dest);
  tmp = (uchar)((uchar)0);
  tmp.s12 = shuffle_fn(source[16]).S05;
  vstore3(tmp, 16, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[17]).S47;
  vstore3(tmp, 17, dest);
  tmp = (uchar)((uchar)0);
  tmp.S10 = shuffle_fn(source[18]).s06;
  vstore3(tmp, 18, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = shuffle_fn(source[19]).s45;
  vstore3(tmp, 19, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = shuffle_fn(source[20]).s33;
  vstore3(tmp, 20, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = shuffle_fn(source[21]).S31;
  vstore3(tmp, 21, dest);
  tmp = (uchar)((uchar)0);
  tmp.s20 = shuffle_fn(source[22]).s62;
  vstore3(tmp, 22, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[23]).S02;
  vstore3(tmp, 23, dest);
  tmp = (uchar)((uchar)0);
  tmp.S12 = shuffle_fn(source[24]).s47;
  vstore3(tmp, 24, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = shuffle_fn(source[25]).S04;
  vstore3(tmp, 25, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[26]).S43;
  vstore3(tmp, 26, dest);
  tmp = (uchar)((uchar)0);
  tmp.s10 = shuffle_fn(source[27]).s37;
  vstore3(tmp, 27, dest);
  tmp = (uchar)((uchar)0);
  tmp.s21 = shuffle_fn(source[28]).s11;
  vstore3(tmp, 28, dest);
  tmp = (uchar)((uchar)0);
  tmp.s20 = shuffle_fn(source[29]).s04;
  vstore3(tmp, 29, dest);
  tmp = (uchar)((uchar)0);
  tmp.S21 = shuffle_fn(source[30]).S12;
  vstore3(tmp, 30, dest);
  tmp = (uchar)((uchar)0);
  tmp.S01 = shuffle_fn(source[31]).s12;
  vstore3(tmp, 31, dest);
}
