  vstore3(tmp, 27, dest);
  tmp = (short)((short)0);
  tmp.S01 = shuffle_fn(source[28]).s31;
  vstore3(tmp, 28, dest);
  tmp = (short)((short)0);
  tmp.S01 = shuffle_fn(source[29]).S23;
  vstore3(tmp, 29, dest);
  tmp = (short)((short)0);
  tmp.S21 = shuffle_fn(source[30]).S10;
  vstore3(tmp, 30, dest);
