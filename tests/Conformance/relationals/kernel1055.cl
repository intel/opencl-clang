// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
uchar3 shuffle_fn(uchar3 source);
uchar3 shuffle_fn(uchar3 source) { return source; }

__kernel void sample_test(__global uchar *source, __global uchar4 *dest) {
