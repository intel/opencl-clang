// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
#pragma OPENCL EXTENSION cl_khr_fp64 : enable
__kernel void sample_test(__global double *source, __global double *dest) {
  if (get_global_id(0) != 0)
    return;
  // double3 src1 /*, src2*/;
  double3 tmp;
  tmp = (double)((double)0);
  tmp.s2 = vload3(0, source).S0;
  vstore3(tmp, 0, dest);
  tmp = (double)((double)0);
  tmp.S1 = vload3(1, source).s0;
  vstore3(tmp, 1, dest);
  tmp = (double)((double)0);
  tmp.s0 = vload3(2, source).S2;
  vstore3(tmp, 2, dest);
  tmp = (double)((double)0);
  tmp.s1 = vload3(3, source).s2;
  vstore3(tmp, 3, dest);
  tmp = (double)((double)0);
  tmp.s1 = vload3(4, source).S2;
  vstore3(tmp, 4, dest);
  tmp = (double)((double)0);
  tmp.S2 = vload3(5, source).s1;
  vstore3(tmp, 5, dest);
  tmp = (double)((double)0);
  tmp.s1 = vload3(6, source).S0;
  vstore3(tmp, 6, dest);
  tmp = (double)((double)0);
  tmp.S0 = vload3(7, source).s1;
  vstore3(tmp, 7, dest);
  tmp = (double)((double)0);
  tmp.S0 = vload3(8, source).S1;
  vstore3(tmp, 8, dest);
  tmp = (double)((double)0);
  tmp.S1 = vload3(9, source).s1;
  vstore3(tmp, 9, dest);
  tmp = (double)((double)0);
  tmp.S0 = vload3(10, source).S2;
  vstore3(tmp, 10, dest);
  tmp = (double)((double)0);
  tmp.s10 = vload3(11, source).S21;
  vstore3(tmp, 11, dest);
  tmp = (double)((double)0);
  tmp.s21 = vload3(12, source).S01;
  vstore3(tmp, 12, dest);
  tmp = (double)((double)0);
  tmp.S21 = vload3(13, source).S20;
  vstore3(tmp, 13, dest);
  tmp = (double)((double)0);
  tmp.s12 = vload3(14, source).s11;
  vstore3(tmp, 14, dest);
  tmp = (double)((double)0);
  tmp.s21 = vload3(15, source).S02;
  vstore3(tmp, 15, dest);
  tmp = (double)((double)0);
  tmp.s20 = vload3(16, source).s01;
  vstore3(tmp, 16, dest);
  tmp = (double)((double)0);
  tmp.s10 = vload3(17, source).s22;
  vstore3(tmp, 17, dest);
  tmp = (double)((double)0);
  tmp.S12 = vload3(18, source).s10;
  vstore3(tmp, 18, dest);
  tmp = (double)((double)0);
  tmp.S20 = vload3(19, source).s11;
  vstore3(tmp, 19, dest);
  tmp = (double)((double)0);
  tmp.s10 = vload3(20, source).s11;
  vstore3(tmp, 20, dest);
  tmp = (double)((double)0);
  tmp.S02 = vload3(21, source).s22;
  vstore3(tmp, 21, dest);
  tmp = (double)((double)0);
  tmp.S20 = vload3(22, source).S22;
  vstore3(tmp, 22, dest);
  tmp = (double)((double)0);
  tmp.S01 = vload3(23, source).S10;
  vstore3(tmp, 23, dest);
  tmp = (double)((double)0);
  tmp.s12 = vload3(24, source).S20;
  vstore3(tmp, 24, dest);
  tmp = (double)((double)0);
  tmp.S10 = vload3(25, source).s12;
  vstore3(tmp, 25, dest);
  tmp = (double)((double)0);
  tmp.S12 = vload3(26, source).s22;
  vstore3(tmp, 26, dest);
  tmp = (double)((double)0);
  tmp.s21 = vload3(27, source).s10;
  vstore3(tmp, 27, dest);
  tmp = (double)((double)0);
  tmp.S21 = vload3(28, source).s10;
  vstore3(tmp, 28, dest);
  tmp = (double)((double)0);
  tmp.S01 = vload3(29, source).s11;
  vstore3(tmp, 29, dest);
  tmp = (double)((double)0);
  tmp.S01 = vload3(30, source).S00;
  vstore3(tmp, 30, dest);
  tmp = (double)((double)0);
  tmp.S01 = vload3(31, source).S11;
  vstore3(tmp, 31, dest);
}
