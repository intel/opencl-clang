// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
__kernel void sample_test(__global short *source, __global short *dest) {
  if (get_global_id(0) != 0)
    return;
  // short src1 /*, src2*/;
  short3 tmp;
  tmp = (short)((short)0);
  tmp.s1 = ((__global short16 *)source)[0].S0;
  vstore3(tmp, 0, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.S1 = ((__global short16 *)source)[0].s1;
  vstore3(tmp, 1, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.S1 = ((__global short16 *)source)[0].S2;
  vstore3(tmp, 2, (__global short *)dest);
  tmp = (short)((short)0);
