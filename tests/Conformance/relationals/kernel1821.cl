  tmp.S2 = ((__global short16 *)source)[1].s9;
  vstore3(tmp, 25, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.S2 = ((__global short16 *)source)[1].SA;
  vstore3(tmp, 26, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.S0 = ((__global short16 *)source)[1].Sb;
  vstore3(tmp, 27, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.s1 = ((__global short16 *)source)[1].SC;
  vstore3(tmp, 28, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.S0 = ((__global short16 *)source)[1].sD;
  vstore3(tmp, 29, (__global short *)dest);
