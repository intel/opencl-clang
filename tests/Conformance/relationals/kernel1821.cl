  tmp = (short)((short)0);
  tmp.S1 = ((__global short16 *)source)[1].S7;
  vstore3(tmp, 23, (__global short *)dest);
  tmp = (short)((short)0);
  tmp.s2 = ((__global short16 *)source)[1].s8;
  vstore3(tmp, 24, (__global short *)dest);
