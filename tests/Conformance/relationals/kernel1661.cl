  dest[22] = tmp;
  tmp = (double)((double)0);
  tmp = shuffle_fn(source[23]).sb;
  dest[23] = tmp;
  tmp = (double)((double)0);
  tmp = shuffle_fn(source[24]).sd;
  dest[24] = tmp;
  tmp = (double)((double)0);
  tmp = shuffle_fn(source[25]).sa;
  dest[25] = tmp;
