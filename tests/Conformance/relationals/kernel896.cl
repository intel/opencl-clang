// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
#pragma OPENCL EXTENSION cl_khr_fp64 : enable
__kernel void sample_test(__global double2 *source, __global double *dest) {
  if (get_global_id(0) != 0)
    return;
  // double2 src1 /*, src2*/;
  double3 tmp;
  tmp = (double)((double)0);
  tmp.S2 = source[0].S1;
  vstore3(tmp, 0, dest);
  tmp = (double)((double)0);
  tmp.s0 = source[1].s1;
  vstore3(tmp, 1, dest);
  tmp = (double)((double)0);
  tmp.S1 = source[2].s1;
  vstore3(tmp, 2, dest);
  tmp = (double)((double)0);
  tmp.s0 = source[3].s1;
  vstore3(tmp, 3, dest);
  tmp = (double)((double)0);
  tmp.S1 = source[4].S1;
  vstore3(tmp, 4, dest);
  tmp = (double)((double)0);
  tmp.s2 = source[5].S1;
  vstore3(tmp, 5, dest);
  tmp = (double)((double)0);
  tmp.s2 = source[6].S1;
  vstore3(tmp, 6, dest);
  tmp = (double)((double)0);
  tmp.S1 = source[7].s0;
  vstore3(tmp, 7, dest);
  tmp = (double)((double)0);
  tmp.s0 = source[8].S0;
  vstore3(tmp, 8, dest);
  tmp = (double)((double)0);
  tmp.S0 = source[9].S1;
  vstore3(tmp, 9, dest);
  tmp = (double)((double)0);
  tmp.s2 = source[10].s0;
  vstore3(tmp, 10, dest);
  tmp = (double)((double)0);
  tmp.S1 = source[11].s0;
  vstore3(tmp, 11, dest);
  tmp = (double)((double)0);
  tmp.s2 = source[12].s1;
  vstore3(tmp, 12, dest);
  tmp = (double)((double)0);
  tmp.s0 = source[13].s1;
  vstore3(tmp, 13, dest);
  tmp = (double)((double)0);
  tmp.S1 = source[14].S0;
  vstore3(tmp, 14, dest);
  tmp = (double)((double)0);
  tmp.S0 = source[15].s1;
  vstore3(tmp, 15, dest);
  tmp = (double)((double)0);
  tmp.S02 = source[16].s11;
  vstore3(tmp, 16, dest);
  tmp = (double)((double)0);
  tmp.s01 = source[17].s10;
  vstore3(tmp, 17, dest);
  tmp = (double)((double)0);
  tmp.s12 = source[18].s01;
  vstore3(tmp, 18, dest);
  tmp = (double)((double)0);
  tmp.s10 = source[19].s11;
  vstore3(tmp, 19, dest);
  tmp = (double)((double)0);
  tmp.S20 = source[20].s01;
  vstore3(tmp, 20, dest);
  tmp = (double)((double)0);
  tmp.S01 = source[21].s00;
  vstore3(tmp, 21, dest);
  tmp = (double)((double)0);
  tmp.S21 = source[22].S11;
  vstore3(tmp, 22, dest);
  tmp = (double)((double)0);
  tmp.s21 = source[23].s00;
  vstore3(tmp, 23, dest);
  tmp = (double)((double)0);
  tmp.S01 = source[24].s01;
  vstore3(tmp, 24, dest);
  tmp = (double)((double)0);
  tmp.s01 = source[25].s10;
  vstore3(tmp, 25, dest);
  tmp = (double)((double)0);
  tmp.S12 = source[26].s01;
  vstore3(tmp, 26, dest);
