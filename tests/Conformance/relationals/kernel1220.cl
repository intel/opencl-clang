// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
ushort8 shuffle_fn(ushort8 source);
ushort8 shuffle_fn(ushort8 source) { return source; }

__kernel void sample_test(__global ushort8 *source, __global ushort *dest) {
  if (get_global_id(0) != 0)
    return;
  // ushort8 src1 /*, src2*/;
  ushort3 tmp;
  tmp = (ushort)((ushort)0);
  tmp.S0 = shuffle_fn(source[0]).s2;
  vstore3(tmp, 0, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[1]).S3;
  vstore3(tmp, 1, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[2]).s3;
  vstore3(tmp, 2, dest);
