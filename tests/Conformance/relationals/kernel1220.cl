  tmp.S02 = shuffle_fn(source[16]).S74;
  vstore3(tmp, 16, dest);
  tmp = (ushort)((ushort)0);
  tmp.S01 = shuffle_fn(source[17]).s62;
  vstore3(tmp, 17, dest);
  tmp = (ushort)((ushort)0);
  tmp.s02 = shuffle_fn(source[18]).s72;
  vstore3(tmp, 18, dest);
  tmp = (ushort)((ushort)0);
  tmp.s01 = shuffle_fn(source[19]).s02;
  vstore3(tmp, 19, dest);
  tmp = (ushort)((ushort)0);
  tmp.s02 = shuffle_fn(source[20]).S45;
  vstore3(tmp, 20, dest);
  tmp = (ushort)((ushort)0);
  tmp.S01 = shuffle_fn(source[21]).s47;
  vstore3(tmp, 21, dest);
  tmp = (ushort)((ushort)0);
  tmp.S10 = shuffle_fn(source[22]).s43;
  vstore3(tmp, 22, dest);
