  vstore3(tmp, 8, dest);
  tmp = (ushort)((ushort)0);
  tmp.S2 = shuffle_fn(source[9]).S0;
  vstore3(tmp, 9, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[10]).s3;
  vstore3(tmp, 10, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = shuffle_fn(source[11]).s31;
  vstore3(tmp, 11, dest);
  tmp = (ushort)((ushort)0);
  tmp.S21 = shuffle_fn(source[12]).s72;
  vstore3(tmp, 12, dest);
  tmp = (ushort)((ushort)0);
  tmp.s10 = shuffle_fn(source[13]).s66;
  vstore3(tmp, 13, dest);
  tmp = (ushort)((ushort)0);
  tmp.S01 = shuffle_fn(source[14]).s27;
  vstore3(tmp, 14, dest);
  tmp = (ushort)((ushort)0);
  tmp.s12 = shuffle_fn(source[15]).S13;
  vstore3(tmp, 15, dest);
