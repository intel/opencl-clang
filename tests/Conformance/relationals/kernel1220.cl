  tmp.S0 = shuffle_fn(source[3]).S0;
  vstore3(tmp, 3, dest);
  tmp = (ushort)((ushort)0);
  tmp.s0 = shuffle_fn(source[4]).S1;
  vstore3(tmp, 4, dest);
