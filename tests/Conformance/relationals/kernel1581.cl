  vstore3(tmp, 18, dest);
  tmp = (float)((float)0);
  tmp.s20 = shuffle_fn(source[19]).s35;
  vstore3(tmp, 19, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[20]).s00;
  vstore3(tmp, 20, dest);
  tmp = (float)((float)0);
  tmp.s02 = shuffle_fn(source[21]).s02;
  vstore3(tmp, 21, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[22]).s43;
  vstore3(tmp, 22, dest);
