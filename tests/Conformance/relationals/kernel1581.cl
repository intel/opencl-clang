  tmp.s2 = shuffle_fn(source[10]).S4;
  vstore3(tmp, 10, dest);
  tmp = (float)((float)0);
  tmp.S01 = shuffle_fn(source[11]).s60;
  vstore3(tmp, 11, dest);
  tmp = (float)((float)0);
  tmp.S12 = shuffle_fn(source[12]).s52;
  vstore3(tmp, 12, dest);
  tmp = (float)((float)0);
  tmp.S02 = shuffle_fn(source[13]).S46;
  vstore3(tmp, 13, dest);
  tmp = (float)((float)0);
  tmp.s21 = shuffle_fn(source[14]).S41;
  vstore3(tmp, 14, dest);
