// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
float8 shuffle_fn(float8 source);
float8 shuffle_fn(float8 source) { return source; }

__kernel void sample_test(__global float8 *source, __global float *dest) {
  if (get_global_id(0) != 0)
    return;
  // float8 src1 /*, src2*/;
  float3 tmp;
  tmp = (float)((float)0);
  tmp.S0 = shuffle_fn(source[0]).S4;
  vstore3(tmp, 0, dest);
  tmp = (float)((float)0);
  tmp.S1 = shuffle_fn(source[1]).s0;
  vstore3(tmp, 1, dest);
  tmp = (float)((float)0);
  tmp.s2 = shuffle_fn(source[2]).s7;
  vstore3(tmp, 2, dest);
