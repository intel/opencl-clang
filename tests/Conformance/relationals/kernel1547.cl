// RUN: %occ-cli %s --cl-options= --cl-device=%cl_device %cfg_path
float2 shuffle_fn(float2 source);
float2 shuffle_fn(float2 source) { return source; }

__kernel void sample_test(__global float2 *source, __global float4 *dest) {
