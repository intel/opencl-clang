  tmp.S02 = shuffle_fn(source[19]).sc8;
  vstore3(tmp, 19, dest);
  tmp = (ulong)((ulong)0);
  tmp.s20 = shuffle_fn(source[20]).s78;
  vstore3(tmp, 20, dest);
