  tmp.S21 = shuffle_fn(source[11]).SB3;
  vstore3(tmp, 11, dest);
  tmp = (ulong)((ulong)0);
  tmp.S01 = shuffle_fn(source[12]).s48;
  vstore3(tmp, 12, dest);
