  vstore3(tmp, 19, dest);
  tmp = (short)((short)0);
  tmp.s02 = shuffle_fn(source[20]).s9F;
  vstore3(tmp, 20, dest);
  tmp = (short)((short)0);
  tmp.S20 = shuffle_fn(source[21]).sCD;
  vstore3(tmp, 21, dest);
