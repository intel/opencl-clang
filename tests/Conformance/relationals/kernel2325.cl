  tmp = (double)((double)0);
  tmp.s2 = ((__global double16 *)source)[1].S7;
  vstore3(tmp, 23, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S2 = ((__global double16 *)source)[1].S8;
  vstore3(tmp, 24, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S0 = ((__global double16 *)source)[1].s9;
  vstore3(tmp, 25, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S1 = ((__global double16 *)source)[1].SA;
  vstore3(tmp, 26, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s0 = ((__global double16 *)source)[1].SB;
  vstore3(tmp, 27, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s1 = ((__global double16 *)source)[1].sc;
  vstore3(tmp, 28, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.s1 = ((__global double16 *)source)[1].Sd;
  vstore3(tmp, 29, (__global double *)dest);
  tmp = (double)((double)0);
  tmp.S0 = ((__global double16 *)source)[1].sE;
  vstore3(tmp, 30, (__global double *)dest);
